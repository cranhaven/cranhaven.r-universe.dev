Package: sidra
Type: Package
Title: Acesso aos Dados do 'SIDRA' do IBGE
Version: 0.1.9
Authors@R: person(given = "Rodrigo Emmanuel", family = "Santana
        Borges", role = c("cre","aut","cph"), email =
        "rodrigo@borges.net.br", comment = "affiliation - Distintive
