Package: minimapR
Title: Wrapper for 'minimap2'
Version: 0.0.1.0
Date: 2024-07-11
Authors@R: c(person("Jake", "Reed", , "hreed.ga@gmail.com", role =
        c("aut", "cre"), comment = c(ORCID = "0000-0002-8384-3593")),
