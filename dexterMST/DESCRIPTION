Package: dexterMST
Type: Package
Title: CML and Bayesian Calibration of Multistage Tests
Version: 0.9.6
Date: 2023-11-21
Authors@R: c(person("Timo", "Bechger", role = c("aut", "cre"), email =
        "tmbechger@gmail.com"), person("Jesse","Koops", role = "aut"),
        person("Ivailo","Partchev", role = "aut"), person("Gunter",
        "Maris", role = "aut"), person("Robert", "Zwitser", role =
