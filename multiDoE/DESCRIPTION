Type: Package
Package: multiDoE
Title: Multi-Criteria Design of Experiments for Optimal Design
Version: 0.9.2
Authors@R: c( person( given = "Francesca", family = "Cucchi", role =
        c("aut") ), person( given = "Andrea", family = "Melloncelli",
        role = c("aut", "cre"), email = "andrea.melloncelli@vanlog.it"
