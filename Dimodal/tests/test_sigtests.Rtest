##### Test Framework

# Run a test -> critval round trip on height/lengths vals for draw size n
# and FIR filter with window size flp.  If basedist is NULL vals is heights
# and we test the peak model, otherwise it is lengths and we test the flat
# model with the given base distribution.  Returns TRUE if the round trip
# passes, and if not also sets the global allpass to FALSE.  testID is an
# identifier added to any failure messages; if NULL then no message is
# printed.
verify.tc <- function(testID, vals, n, flp, filter, basedist) {

  passed <- TRUE

  if (is.null(basedist)) {
    tst <- Dipeak.test(vals, n, flp, filter, lower.tail=FALSE)
    pval <- tst$p.value
    recovered <- Dipeak.critval(pval, n, flp, filter)
    feat <- 'peak'

    # Very small Dipeak.test values map back with increasing inaccuracy.
    # To maintain a fairly tight match in the nearly check we drop them.
    # The alternative is to relax the nearly epsilon, perhaps with pval,
    # and to handle Inf recovered results.
    bad <- !is.finite(pval) | (pval < 5.0e-14)
    if (any(bad)) {
      vals <- vals[!bad]
      recovered <- recovered[!bad]
      if (!is.null(testID)) {
        cat('    test ', testID, ' ignored ', sum(bad), ' tiny signif levels\n')
      }
    }
  } else {
    tst <- Diflat.test(vals, n, flp, filter, basedist, lower.tail=FALSE)
    recovered <- Diflat.critval(tst$p.value, n, flp, filter, basedist)
    feat <- 'flat'
  }

  if ((0 < length(vals)) && !nearly(vals, recovered, 1e-4)) {
    if (!is.null(testID)) {
     fail <- which(!nearly(vals, recovered, 1e-4))
      cat('    test ', testID, feat, 't->cv->t did not recover values\n')
      cat('      orig  ', vals[fail], '  pval ', pval[fail], '  back ',
          recovered[fail], '\n')
    }
    allpass <<- FALSE
    passed <- FALSE
  }

  passed
}

# Run a critval -> test round trip on significance levels pvals for draw size
# n and FIR filter with window size flp.  If basedist is NULL check the peak
# model, otherwise use it as the null variate.  Returns TRUE if the round
# trip passes, and if not also sets the global allpass to FALSE.  testID is
# an identifier added to any failure messages; if NULL then no message is
# printed.
verify.ct <- function(testID, pvals, n, flp, filter, basedist) {

  passed <- TRUE

  if (is.null(basedist)) {
    vals <- Dipeak.critval(pvals, n, flp, filter)
    tst <- Dipeak.test(vals, n, flp, filter, lower.tail=FALSE)
    recovered <- tst$pval
    feat <- 'peak'
  } else {
    vals <- Diflat.critval(pvals, n, flp, filter, basedist)
    tst <- Diflat.test(vals, n, flp, filter, basedist, lower.tail=FALSE)
    recovered <- tst$p.value
    feat <- 'flat'

    # Ignore failed critval results, which can never map back to finite
    # significance levels.
    bad <- !is.finite(vals)
    if (any(bad)) {
      pvals <- pvals[!bad]
      recovered <- recovered[!bad]
      if (!is.null(testID)) {
        cat('    test ', testID, ' ignored ', sum(bad), ' non-finite critval\n')
      }
    }
  }

  if ((0 < length(pvals)) && !nearly(pvals, recovered, 1e-4)) {
    if (!is.null(testID)) {
      fail <- which(!nearly(pvals, recovered, 1e-4))
      cat('    test ', testID, feat, 'cv->t->cv did not recover quantile\ns')
      cat('      orig ', pvals[fail], '  crit ', vals[fail], '  back ',
          recovered[fail], '\n')
    }
    allpass <<- FALSE
    passed <- FALSE
  }

  passed
}

# Compare the Diexcurht results ht1 and ht2.  testID is a label for failure
# messages.  Returns TRUE if the results are the same, FALSE if not.  Also
# on any failure the global allpass is set to FALSE.
verify.excurht <- function(testID, ht1, ht2) {

  passed <- TRUE

  if (length(ht1$statistic) != length(ht2$statistic)) {
    cat('    test ', testID, ' statistics lengths differ\n')
    passed <- FALSE
  } else if (!nearly(ht1$statistic, ht2$statistic, 0.001)) {
    cat('    test ', testID, ' statistics differ\n')
    if (length(ht1$statistic) <= 3) {
      sep <- " vs "
    } else {
      sep <- "\n      "
    }
    cat('      ', ht1$statistic, sep, ht2$statistic, '\n')
    passed <- FALSE
  }

  if (length(ht1$p.value) != length(ht2$p.value)) {
    cat('    test ', testID, ' p.value lengths differ\n')
    passed <- FALSE
  } else if (!nearly(ht1$p.value, ht2$p.value, 0.005, 0.03)) {
    cat('    test ', testID, ' p.values differ\n')
    if (length(ht1$p.value) <= 3) {
      sep <- " vs "
    } else {
      sep <- "\n      "
    }
    cat('      ', paste0(sprintf('%6.4f', ht1$p.value)),
        sep, paste0(sprintf('%6.4f', ht2$p.value)), '\n')
    passed <- FALSE
  }

  if (length(ht1$critval) != length(ht2$critval)) {
    cat('    test ', testID, ' critval lengths differ\n')
    cat('      ', ht1$critval, ' vs. ', ht2$critval, '\n')
    passed <- FALSE
  } else if (all(is.na(ht1$critval)) || all(is.na(ht2$critval))) {
    if (!nearly(ht1$critval, ht2$critval, 0.001)) {
      cat('    test ', testID, ' critical values differ\n')
      cat('      ', ht1$critval, ' vs ', ht2$critval, '\n')
      passed <- FALSE
    }
  } else {
    keep.cv <- !is.na(ht1$critval) & !is.na(ht2$critval)
    cv1 <- ht1$critval[keep.cv]
    cv2 <- ht2$critval[keep.cv]
    if (!nearly(cv1, cv2, 0.01, 0.05)) {
      cat('    test ', testID, ' critical values differ\n')
      cat('      ', paste0(sprintf('%8.5f', cv1)), '\n')
      cat('      ', paste0(sprintf('%8.5f', cv2)), '\n')
      passed <- FALSE
    }
    # Or, relative error ...
    # cv1 <- ht1$critval[keep.cv]
    # cv2 <- ht2$critval[keep.cv]
    # relerr <- abs(cv1 - cv2) * 2 / (cv1 + cv2)
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Compare the Dipermht.test results ht1, ht2, with looser matching than
# for verify.excurht.  testID is a label for failure messages.  Returns
# whether the results are the same, a boolean, and sets the global allpass
# to FALSE on any mis-match.
verify.permht <- function(testID, ht1, ht2) {

  passed <- TRUE

  if (length(ht1$statistic) != length(ht2$statistic)) {
    cat('    test ', testID, ' statistics lengths differ\n')
    passed <- FALSE
  } else if (!nearly(ht1$statistic, ht2$statistic, 0.001)) {
    cat('    test ', testID, ' statistics differ\n')
    if (length(ht1$statistic) <= 3) {
      sep <- " vs "
    } else {
      sep <- "\n      "
    }
    cat('      ', ht1$statistic, sep, ht2$statistic, '\n')
    passed <- FALSE
  }

  # The permutation generator changed between the development version and
  # here, and the p and critical values no longer match exactly.  We
  # allow half a point difference in p and one in the critical values
  # (since they are integer heights).
  # The choice of the random seed and nperm also affect the stability.

  if (length(ht1$p.value) != length(ht2$p.value)) {
    cat('    test ', testID, ' p.value lengths differ\n')
    passed <- FALSE
  } else if (!nearly(ht1$p.value, ht2$p.value, 0.005)) {
    cat('    test ', testID, ' p.values differ\n')
    if (length(ht1$p.value) <= 3) {
      sep <- " vs "
    } else {
      sep <- "\n      "
    }
    cat('      ', paste0(sprintf('%6.4f', ht1$p.value)),
        sep, paste0(sprintf('%6.4f', ht2$p.value)), '\n')
    passed <- FALSE
  }

  if (length(ht1$critval) != length(ht2$critval)) {
    cat('    test ', testID, ' critval lengths differ\n')
    passed <- FALSE
  } else if (all(is.na(ht1$critval)) || all(is.na(ht2$critval))) {
    if (!nearly(ht1$critval, ht2$critval, 1)) {
      cat('    test ', testID, ' critical values differ\n')
      cat('      ', ht1$critval, ' vs. ', ht2$critval, '\n')
      passed <- FALSE
    }
  } else {
    keep.cv <- !is.na(ht1$critval) & !is.na(ht2$critval)
    if (0 == sum(keep.cv)) {
      cat('    test ', testID, ' no critical values\n')
      passed <- FALSE
    } else {
      if (!nearly(ht1$critval[keep.cv], ht2$critval[keep.cv], 0)) {
        cat('    test ', testID, ' critical values differ\n')
        cat('      ', ht1$critval, ' vs. ', ht2$critval, '\n')
        passed <- FALSE
      }
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Generate a data frame with ntest test cases of random parameter combinations.
# flowq is the fraction of tests that generate q values outside the model
# range (ie. < 0.90).  seed sets the random number seed beforehand.  The
# data frame has columns
#   $n        draw size (50 t/m 600)
#   $flp      kernel size (0.05 t/m 0.25)
#   $ht       peak heights (0.1 t/m 10.0)
#   $len      flat lengths (1 t/m n-1)
#   $q        quantile, of which ntest*flowq are below 0.9, the others above
#   $filter   FIR filter type
#   $base     base distribution for flats, weighted towards logistic
# These values are _not_ consistent within a row, especially the quantile is
# independent of the length and height.  Use to test either round-trip.
gen.stress <- function(ntest, seed=17, flowq=0.05) {

  set.seed(seed)

  nlowq <- round(ntest * flowq)
  filters <- c('kaiser', 'hanning', 'hamming', 'bartlett', 'gaussian', 'normal',
               'blackman')
  basedists <- c('logistic', 'gumbel', 'normal', 'gaussian', 'weibull')

  tsts <- data.frame(n=round(runif(ntest, 50, 500)),
                     flp=runif(ntest, 0.05, 0.30),
                     ht=runif(ntest, 0.1, 10.0),
                     len=runif(ntest, 0.1, 0.4),
                     q=c(10^runif(ntest-nlowq, log10(0.9), log10(0.999999)),
                         runif(nlowq, 0, 0.9)),
                     filter=sample(filters, ntest, replace=TRUE,
                                   prob=c(0.5, 0.1, 0.1, 0.1, 0.05,0.05, 0.1)),
                     base=sample(basedists, ntest, replace=TRUE,
                                 prob=c(0.7, 0.1, 0.05,0.05, 0.1)))

  # Guarantee that 1 <= len < n.
  tsts$len <- pmax(1, pmin(round(tsts$len * tsts$n), tsts$n-1))
  tsts$len[tsts$len==0] <- 1
  tsts$len[tsts$len==tsts$n] <- tsts$n[tsts$len==tsts$n] - 1

  tsts
}

# For each test setup in the gen.stress result tests, try all test/critval
# cycles for peaks and flats.  Print the first ten failures, plus a count
# if there's more.  Counts on the individual cycle functions to set the
# global allpass FALSE on failures.
run.stress <- function(tests) {

  passed <- TRUE
  nfail <- 0
  maxfail <- 20

  for (i in 1:nrow(tests)) {
    r <- tests[i,]
    # This quiets the individual tests.
    testID <- NULL
    if (nfail <= maxfail) {
#      testID <- paste0('stress test row ', i)
    }
    peak.tc <- verify.tc(testID, r$ht, r$n, r$flp, r$filter, NULL)
    peak.ct <- verify.ct(testID, r$q, r$n, r$flp, r$filter, NULL)
    flat.tc <- verify.tc(testID, r$len, r$n, r$flp, r$filter, r$base)
    flat.ct <- verify.ct(testID, r$q, r$n, r$flp, r$filter, r$base)

    if (!all(peak.tc, peak.ct, flat.tc, flat.ct)) {
      nfail <- nfail + 1
      if (nfail <= maxfail) {
        cat('    stress test row ', i, ' failed')
        if (!peak.tc) { cat(' peak test->cv') }
        if (!peak.ct) { cat(' peak cv->test') }
        if (!flat.tc) { cat(' flat test->cv') }
        if (!flat.ct) { cat(' flat cv->test') }
        cat('\n')
      }
      passed <- FALSE
    }
  }

  if (maxfail < nfail) {
    cat('      plus ', nfail-maxfail, 'additional failures\n')
  }

  passed
}

# Determine the height of the feature in data x between indices stID and
# endID (incl.).
fht <- function(x, stID, endID) {

  diff(range(x[stID:endID]))
}

# Duplicate the 'Diw' row of the Didata matrix for data x and interval
# spacing width w (fractional or absolute).  This is the interval spacing
# with w NA at the front and attributes 'wdiw' and 'diw.stID', but as a
# vector not a matrix.
mock.diw <- function(x, w) {

  if (w < 1.0) {
    wdiw <- round(w * length(x))
  } else {
    wdiw <- round(w)
  }

  diw <- c(rep(NA, wdiw), diff(sort(x), lag=wdiw))
  attributes(diw) <- c(attributes(diw), list(wdiw=wdiw, diw.stID=wdiw+1))
  diw
}

# Duplicate the 'signed' row of the Didata matrix for data x and interval
# spacing width w (fractional or absolute).  Values are integers.
mock.signed <- function(x, w) {

  if (w < 1.0) {
    wdiw <- round(w * length(x))
  } else {
    wdiw <- round(w)
  }
  
  diw <- c(rep(NA, wdiw), diff(sort(x), lag=wdiw))
  as.integer(c(NA, sign(diff(diw))))
}



