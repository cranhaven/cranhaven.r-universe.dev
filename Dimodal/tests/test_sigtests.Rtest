### Feature Height via Excursion (EH) Tests

if (('all' == testing) || ('excur' %in% testing)) {

## Expected values from development version.  The sampling in the C version
## has changed, which is absorbed by the relative difference check added to
## verify.excurht/nearly or by increasing sample sizes.

diw <- mock.diw(faithful$eruptions, 24)
xbase <- diff(diw[!is.na(diw)])
# Peak at 90% support.  minmin 38-232, max at 115.
stID <- 47
endID <- 126
# Expected values from development version.
exp <- list(statistic=1.1830, p.value=0.0018,
            critval=c(0.6030, 0.7020, 0.9140, NA))
# Note ndraw is not endID-stID+1 because we lose 1 for the diff.
tst <- Diexcurht.test(fht(diw, stID,endID), endID-stID, xbase, 5000, TRUE,FALSE, 21)
verify.excurht('excurht 1', tst, exp)

# Flat at 0.075 ripple.
stID <- 155
endID <- 231
exp <- list(statistic=0.068, p.value=0.000, critval=c(NA, 0.150, 0.200, 0.233))
tst <- Diexcurht.test(fht(diw, stID,endID), endID-stID, xbase, 7500, FALSE,TRUE, 17)
verify.excurht('excurht 2', tst, exp)


diw <- mock.diw(tstds2, 24)
xbase <- diff(diw[!is.na(diw)])
# Peak at 90% support.  minmin 55-182, max at 142.
