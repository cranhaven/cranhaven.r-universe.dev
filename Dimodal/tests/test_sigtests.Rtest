### Number Runs (KR) and Max Run Length (RL) Tests

if (('all' == testing) || ('runs' %in% testing)) {

## Constructed sequences.

# Symmetric transition matrix, 2/32 off diagonal, 10/32 on diagonal.
x <- c(rep(0L, 10), rep(1L,10), rep(2L,10), rep(3L,10),
       0, 2, 1, 3, 1, 0, 3, 2, 0, 0, 1, 1, 2, 2, 3, 3,
       0, 2, 1, 3, 1, 0, 3, 2, 0)
# 17x 0, 16x 1, 16x 2, 16x3.   25 runs per rle.
# a1 = 65, a2 = 3*(17*16) + 3(16*16), a3 = 3*(17*16*16) + (16*16*16).
#   E = 47.74, V = 11.62, z = (25-E)/sqrt(v) = -6.670946.
exp.nr <- c(25, 49.73846154, 11.61621302, 1.958598e-13)
pruns <- Dinrun.test(x, 1, length(x), 0, TRUE)
res <- with(pruns, c(statistic, parameter$Erun, parameter$Vrun, p.value))
verify.vectors('KR9', res, exp.nr)
exp.tmat <- matrix(c(rep(c(10, 2, 2, 2, 2), 3), 10), nrow=4, byrow=TRUE) / 16
exp.smat <- rep(0.25, 4)
exp.rl <- c(10, 65, 0.1017787)
prl <- Dirunlen.test(x, 1, length(x), 0)
res <- with(prl, c(statistic, parameter$featlen, p.value))
verify.vectors('RL9', res, exp.rl)
verify.vectors('RL9tmat', prl$tmat, exp.tmat)
verify.vectors('RL9wt', prl$wt, exp.smat)

# Symmetric transition matrix, 2/18 off diagonal, 6/18 on diagonal.
x <- c(rep(0L,6), rep(1L,6), rep(2L,6), 1, 0, 2,
       rep(0L,2), rep(1L,2), rep(2L,2), 1, 0, 2, 0)
# 11x 0, 10x 1, 10x 2.  rle says 13 runs.
# a1 = 31, a2 = 2*11*10 + 10*10, a3 = 11*10*10.
#   E = 21.64516, V = 6.422477
exp.nr <- c(13, 21.64516129, 6.422476587, 0.0003232517)
pruns <- Dinrun.test(x, 1, length(x), 0, FALSE)
res <- with(pruns, c(statistic, parameter$Erun, parameter$Vrun, 1-p.value))
verify.vectors('KR10', res, exp.nr)
exp.tmat <- matrix(c(rep(c(6,2,2,2), 2), 6), nrow=3, byrow=TRUE) / 10
exp.smat <- rep(1/3, 3)
exp.rl <- c(6, 31, 0.2174641)
prl <- Dirunlen.test(x, 1, length(x), 0)
res <- with(prl, c(statistic, parameter$featlen, p.value))
verify.vectors('RL10', res, exp.rl)
verify.vectors('RL10tmat', prl$tmat, exp.tmat)
verify.vectors('RL10wt', prl$wt, exp.smat)

## Expected values from development version.

sdiw <- mock.signed(faithful$eruptions, 16)
endpts <- c(36, 125, 160, 221, 257)
exp.nr <- c(0.5215094, 0.5552983, 0.7708809, 0.4270489)
pruns <- Dinrun.test(sdiw, endpts[-length(endpts)]+1, endpts[-1L], 0, TRUE)
verify.vectors('KR1', pruns$p.value, exp.nr)
exp.rl <- c(0.3124169, 0.3520344, 0.1874553, 0.3475706)
prl <- Dirunlen.test(sdiw, endpts[-length(endpts)]+1, endpts[-1L], 0)
verify.vectors('RL1', prl$p.value, exp.rl)

sdiw <- mock.signed(quakes[,3], 100)
endpts <- c(101, 117, 508, 923)
exp.nr <- c(0.0983528, 0.8968052, 0.1648317)
pruns <- Dinrun.test(sdiw, endpts[-length(endpts)]+1, endpts[-1L], 0, TRUE)
