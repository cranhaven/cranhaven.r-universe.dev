### Feature Height via Runs Permutation (PH) Tests

if (('all' == testing) || ('perm' %in% testing)) {

## Expected values initially from development version, before shifting to
## mid-distribution in C version (manually checking width from permutation).

diw <- mock.diw(tstds4, 36)
# Peak between minima.  dsign has -1, +1 so two state test.
stID <- 106
endID <- 136
dsign <- sign(diff(diw[stID:endID]))
runs <- rle(dsign) ; runs <- runs$lengths * runs$values
exp <- list(statistic=9, p.value=0.0058, critval=c(8, 8, 9, 9))
pht <- Dipermht.test(diff(range(cumsum(dsign))), runs, 5000, FALSE, 11)
verify.permht('permht 1', pht, exp)

stID <- 136
endID <- 226
# dsign has -1, +1 so two state test.
dsign <- sign(diff(diw[stID:endID]))
runs <- rle(dsign) ; runs <- runs$lengths * runs$values
exp <- list(statistic=18, p.value=0.0206, critval=c(15, 16, 19, 19))
pht <- Dipermht.test(diff(range(cumsum(dsign))), runs, 5000, FALSE, 11)
verify.permht('permht 2', pht, exp)

diw <- mock.diw(faithful$eruptions, 24)
# Peak between minima.  dsign has -1, 0, +1, so three state test.
stID <- 38
endID <- 232
dsign <- sign(diff(diw[stID:endID]))
runs <- rle(dsign) ; runs <- runs$lengths * runs$values
exp <- list(statistic=27, p.value=0.0029, critval=c(19, 21, 25, 26))
pht <- Dipermht.test(diff(range(cumsum(dsign))), runs, 5000, FALSE, 3)
verify.permht('permht 3', pht, exp)

# This triggered a bad 3 symbol sequence in alt.permute.  Verify fix.
diw <- mock.diw(faithful$waiting, 27)
# Peak between minima, with three symbols (1x -1, 3x 0, 1x 1).
stID <- 75
endID <- 82
dsign <- sign(diff(diw[stID:endID]))
runs <- rle(dsign) ; runs <- runs$lengths * runs$values
# Note mid-quantile approximation in middle of equal values.
exp <- list(statistic=1, p.value=0.5, critval=c(1,1,1,1))
pht <- Dipermht.test(diff(range(cumsum(dsign))), runs, 5000, FALSE, 2)
verify.permht('permht 4', pht, exp)

## Interior Tests

# Full enumeration of permutations, without sign screening.
# Expected values copied from e1071:permutations.

exp <- matrix(c(1,2, 2,1), nrow=2, byrow=TRUE)
perm <- permute.all(1:2)
verify.matrices('permute.all n=2', perm, exp)

exp <- matrix(c(1, 2, 3,   2, 1, 3,   2, 3, 1,
                1, 3, 2,   3, 1, 2,   3, 2, 1),
              nrow=6, byrow=TRUE)
perm <- permute.all(1:3)
verify.matrices('permute.all n=3', perm, exp)

exp <- matrix(c( 1, 2, 3, 4,   2, 1, 3, 4,   2, 3, 1, 4,
                 1, 3, 2, 4,   3, 1, 2, 4,   3, 2, 1, 4,
                 2, 3, 4, 1,   1, 3, 4, 2,   3, 1, 4, 2,
                 3, 2, 4, 1,   1, 2, 4, 3,   2, 1, 4, 3,
                 3, 4, 1, 2,   3, 4, 2, 1,   1, 4, 2, 3,
                 2, 4, 1, 3,   2, 4, 3, 1,   1, 4, 3, 2,
                 4, 1, 2, 3,   4, 2, 1, 3,   4, 2, 3, 1,
                 4, 1, 3, 2,   4, 3, 1, 2,   4, 3, 2, 1),
              nrow=24, byrow=TRUE)
perm <- permute.all(1:4)
verify.matrices('permute.all n=4', perm, exp)

