## Stress Tests

# BTP tests based on permht 3.
diw <- mock.diw(faithful$eruptions, 24)
stID <- 38
endID <- 232
dsign <- sign(diff(diw[stID:endID]))
runs <- rle(dsign) ; runs <- runs$lengths * runs$values

verify.error('BTP PH1', Dipermht.test,
             list(xbase=runs, nperm=4000, lower.tail=FALSE, seed=3))

runs.bad <- rle(c(NA, NA, dsign[1:50], NA,NA,NA, dsign[51:length(dsign)], NA))
runs.bad <- runs.bad$lengths * runs.bad$values
verify.error('BTP PH2', Dipermht.test,
             list(diff(range(cumsum(dsign))), runs.bad, 4000, FALSE, 3))

runs.bad <- rle(c(NaN, dsign[1:50], NaN,NaN, dsign[51:length(dsign)], NaN,NaN))
runs.bad <- runs.bad$lengths * runs.bad$values
verify.error('BTP PH3', Dipermht.test,
             list(diff(range(cumsum(dsign))), runs.bad, 4000, FALSE, 3))

runs.bad <- rle(c(Inf,Inf, dsign[1:50], Inf,Inf, dsign[51:length(dsign)], Inf))
runs.bad <- runs.bad$lengths * runs.bad$values
verify.error('BTP PH4', Dipermht.test,
             list(diff(range(cumsum(dsign))), runs.bad, 4000, FALSE, 3))

runs.bad <- rle(c(-Inf, dsign[1:50], -Inf, dsign[51:length(dsign)]))
runs.bad <- runs.bad$lengths * runs.bad$values
verify.error('BTP PH5', Dipermht.test,
             list(diff(range(cumsum(dsign))), runs.bad, 4000, FALSE, 3))

runs.bad <- unlist(list('a', 'b', runs[1:25], 'c', runs[26:length(runs)]))
verify.error('BTP PH6', Dipermht.test,
             list(diff(range(cumsum(dsign))), runs.bad, 4000, FALSE, 3))

exp <- list(statistic=c(NA), p.value=c(NA), critval=numeric(0))
pht <- Dipermht.test(diff(range(cumsum(dsign))), NULL, 4000, FALSE, 3)
verify.permht('BTP PH7', pht, exp)

# See permht 3 for critval change.
exp <- list(statistic=c(NA, NaN), p.value=c(NA, NA), critval=c(19, 21, 25, 26))
pht <- Dipermht.test(c(NA, NaN), runs, 4000, FALSE, 3)
verify.permht('BTP PH8', pht, exp)

# See permht 3 for p.value and critval.
exp <- list(statistic=c(26.5, 28), p.value=c(0.0036, 0.0015),
            critval=c(19, 21, 25, 26))
pht <- Dipermht.test(c(26.5, 28), runs, 4000, FALSE, 3)
verify.permht('BTP PH9', pht, exp)

verify.error('BTP PH10a', Dipermht.test, list('a', runs, 4000, FALSE, 3))
verify.error('BTP PH10b', Dipermht.test, list(27i, runs, 4000, FALSE, 3))
verify.error('BTP PH10c', Dipermht.test, list(list(27), runs, 4000, FALSE, 3))
verify.error('BTP PH10d', Dipermht.test, list(-1, runs, 4000, FALSE, 3))

verify.error('BTP PH11a', Dipermht.test, list(27, runs, 'a', FALSE, 3))
verify.error('BTP PH11b', Dipermht.test, list(27, runs, NA, FALSE, 3))
verify.error('BTP PH11c', Dipermht.test, list(27, runs, NaN, FALSE, 3))
verify.error('BTP PH11d', Dipermht.test, list(27, runs, Inf, FALSE, 3))
verify.error('BTP PH11e', Dipermht.test, list(27, runs, 0, FALSE, 3))

exp <- list(statistic=27, p.value=0.0029, critval=c(19, 21, 25, 26))
pht <- Dipermht.test(diff(range(cumsum(dsign))), runs, c(4000.1,5000), FALSE, 3)
verify.permht('BTP PH12', pht, exp)

verify.error('BTP PH13', Dipermht.test, list(27, runs, 0, 'a', 3))

diw <- mock.diw(rep(0,100), 10)
dsign <- sign(diff(diw[!is.na(diw)]))
runs <- rle(dsign) ; runs <- runs$lengths
exp <- list(statistic=NA, p.value=NA, critval=numeric())
pht <- Dipermht.test(diff(range(cumsum(dsign))), runs, 2000, FALSE, 2)
verify.permht('BTP PH14', pht, exp)

# Permutations = (1, 2), upper tail is halfway through 1 plus 2.
exp <- list(statistic=1, p.value=0.75, critval=matrix(c(2,2,2,2), nrow=1))
pht <- Dipermht.test(1, c(1,2, -1), 5000, FALSE, 2)
verify.permht('BTP PH15', pht, exp)

# Permutations (10x1, 2,2), upper tail is 7 of 12.
exp <- list(statistic=1, p.value=0.5833, critval=matrix(c(2,2,2,2), nrow=1))
pht <- Dipermht.test(1, c(1,1,0,-1), 5000, FALSE, 2)
verify.permht('BTP PH16a', pht, exp)

# Same permutations as 16a but lower tail.
exp <- list(statistic=1, p.value=0.4167, critval=matrix(c(1,1,1,1), nrow=1))
pht <- Dipermht.test(1, c(1,0,-1,-1), 5000, TRUE, 2)
verify.permht('BTP PH16b', pht, exp)

# Permutations (40x1, 8x2), upper tail is 4 of 48.
exp <- list(statistic=2, p.value=0.0833, critval=matrix(c(2,2,2,2), nrow=1))
pht <- Dipermht.test(2, c(-1,-1,0,1,1), 5000, FALSE, 2)
verify.permht('BTP PH16c', pht, exp)

exp <- list(statistic=1, p.value=0.5, critval=matrix(c(1,1,1,1), nrow=1))
pht <- Dipermht.test(1, c(1,0,-1, 0), 5000, TRUE, 2)
verify.permht('BTP PH17', pht, exp)

exp <- list(statistic=0, p.value=1.0, critval=matrix(c(1,1,1,1), nrow=1))
pht <- Dipermht.test(0, c(1,0,-1, 0), 5000, FALSE, 2)
verify.permht('BTP PH18', pht, exp)

exp <- list(statistic=2, p.value=0.0, critval=matrix(c(1,1,1,1), nrow=1))
pht <- Dipermht.test(2, c(1,0,-1, 0), 5000, FALSE, 2)
verify.permht('BTP PH19', pht, exp)

# testing check for permutations.
}


