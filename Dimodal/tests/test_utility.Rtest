## runs.as.rle

# Data is integer so no fuzzy runs.
if ('faithful' %in% data()$results[,3]) {
  x <- diff(sort(faithful$waiting), lag=20)
  r <- find.runs(x, 0.001)
  encode <- rle(x)
  transcode <- runs.as.rle(r, x)
  verify.vectors(8.1, transcode$lengths, encode$lengths)
  verify.vectors(8.2, transcode$values, encode$values)
  verify.vectors(8.3, transcode$nskip, rep(0, length(transcode$lengths)))
}


## midquantile

# When forming the expected segments, for types 1-3 the q drop tied indices
# after the first.  type 1/3 x is at middle of xuniq,
# ie. (xuniq[-1]+xuniq[-length(xuniq)]) / 2.  

# From Genton, Ma, Parzen "Discussion of 'Sur une limitation tres
# generale ...'".
x <- c(0L, 2L, 3L, 3L, 4L, 4L, 5L, 9L, 10L, 12L)
nx <- length(x)
xuniq <- sort(unique(x))
nuniq <- length(xuniq)
xstep <- c(xuniq[1L], (xuniq[-1L]+xuniq[-nuniq])/2, xuniq[nuniq])
tied <- which(x[-1L]==x[-nx])
qID <- (-1:(nx-1))[-tied-1]

seg <- .Call('C_midq', x, 1L, 0.00, PACKAGE='Dimodal')
verify.vectors("9.1x", seg$x, xstep)
verify.vectors("9.1q", seg$q, qID/(nx-1))
seg <- .Call('C_midq', x, 2L, 0.00, PACKAGE='Dimodal')
verify.vectors("9.2x", seg$x, c(xuniq[1], xuniq))
verify.vectors("9.2q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 3L, 0.00, PACKAGE='Dimodal')
verify.vectors("9.3x", seg$x, xstep)
verify.vectors("9.3q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 4L, 0.00, PACKAGE='Dimodal')
verify.vectors("9.4x", seg$x, xuniq)
verify.vectors("9.4q", seg$q, c(0, 1, 2.5, 4.5, 6, 7, 8, 9)/(nx-1))

xq <- midquantile(x, type=1)
exp <- c(2, 5, 6, 7, 8, 9, 14, 19, 22, 24) / 2
verify.vectors(9.5, xq, exp)

xq <- midquantile(x, type=2)
exp <- c(0, 1, 2+(1/4), 2+(3/4), 3+(1/4), 3+(3/4), 4.5, 7.0, 9.5, 11.0)
verify.vectors(9.6, xq, exp)

xq <- midquantile(x, type=3)
exp <- c(0.5, 1.75, 2.75, 3.25, 3.75, 4.25, 5.75, 8.25, 10.25, 11.5)
verify.vectors(9.7, xq, exp)

xq <- midquantile(x, type=4)
exp <- c(0, 2+(((1:2)-1)/(2.5-1)), 3+(((3:4)-2.5)/(4.5-2.5)),
         4+((5-4.5)/(6-4.5)), 5, 9, 10, 12)
verify.vectors(9.8, xq, exp)

# Generalize to longer sequences than 2.
x <- c(0L, 2L, 3L, 3L, 3L, 4L, 4L, 4L, 4L, 5L, 9L, 10L, 10L, 12L)
nx <- length(x)
xuniq <- sort(unique(x))
nuniq <- length(xuniq)
xstep <- c(xuniq[1L], (xuniq[-1L]+xuniq[-nuniq])/2, xuniq[nuniq])
tied <- which(x[-1L]==x[-nx])
qID <- (-1:(nx-1))[-tied-1]

seg <- .Call('C_midq', x, 1L, 0.00, PACKAGE='Dimodal')
verify.vectors("10.1x", seg$x, xstep)
verify.vectors("10.1q", seg$q, qID/(nx-1))
seg <- .Call('C_midq', x, 2L, 0.00, PACKAGE='Dimodal')
verify.vectors("10.2x", seg$x, c(xuniq[1], xuniq))
verify.vectors("10.2q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 3L, 0.00, PACKAGE='Dimodal')
verify.vectors("10.3x", seg$x, xstep)
verify.vectors("10.3q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 4L, 0.00, PACKAGE='Dimodal')
verify.vectors("10.4x", seg$x, xuniq)
verify.vectors("10.4q", seg$q, c(0, 1, 3, 6.5, 9, 10, 11.5, 13)/(nx-1))

xq <- midquantile(x, type=1)
exp <- c(2, 5, 5+(2/3), 6+(1/3), 7, 7.5, 8, 8.5, 9, 14, 19, 20.5, 22, 24) / 2
verify.vectors(10.5, xq, exp)

xq <- midquantile(x, type=2)
exp <- c(0, 1, 2+(1/6), 2+(3/6), 2+(5/6), 3+(1/8), 3+(3/8), 3+(5/8), 3+(7/8),
         4.5, 7.0, 9+(1/4), 9+(3/4), 11)
verify.vectors(10.6, xq, exp)

xq <- midquantile(x, type=3)
exp <- c(0.5, 1.75, 2+(2/3), 3, 3+(1/3), 3+(5/8), 3+(7/8), 4+(1/8), 4+(3/8),
         5.75, 8.25, 9+(7/8), 10+(5/8), 11.5)
verify.vectors(10.7, xq, exp)

xq <- midquantile(x, type=4)
exp <- c(0, 2+(((1:2)-1)/(3-1)), 3+(((3:6)-3)/(6.5-3)),
         4+(((7:8)-6.5)/(9-6.5)), 5, 9+(((10:11)-10)/(11.5-10)),
         10+(2*((12:13)-11.5)/(13-11.5)))
verify.vectors(10.8, xq, exp)

# Move 4 values to 5 for longer run.
x <- c(0L, 2L, 3L, 3L, 3L, 5L, 5L, 5L, 5L, 5L, 9L, 10L, 10L, 12L)
nx <- length(x)
xuniq <- sort(unique(x))
nuniq <- length(xuniq)
xstep <- c(xuniq[1L], (xuniq[-1L]+xuniq[-nuniq])/2, xuniq[nuniq])
tied <- which(x[-1L]==x[-nx])
qID <- (-1:(nx-1))[-tied-1]

seg <- .Call('C_midq', x, 1L, 0.00, PACKAGE='Dimodal')
verify.vectors("11.1x", seg$x, xstep)
verify.vectors("11.1q", seg$q, qID/(nx-1))
seg <- .Call('C_midq', x, 2L, 0.00, PACKAGE='Dimodal')
verify.vectors("11.2x", seg$x, c(xuniq[1], xuniq))
verify.vectors("11.2q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 3L, 0.00, PACKAGE='Dimodal')
verify.vectors("11.3x", seg$x, xstep)
verify.vectors("11.3q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 4L, 0.00, PACKAGE='Dimodal')
verify.vectors("11.4x", seg$x, xuniq)
verify.vectors("11.4q", seg$q, c(0, 1, 3, 7, 10, 11.5, 13)/(nx-1))

xq <- midquantile(x, type=1)
exp <- c(2, 5, 6, 7, 8, 9.2, 10.4, 11.6, 12.8, 14, 19, 20.5, 22, 24) / 2
verify.vectors(11.5, xq, exp)

xq <- midquantile(x, type=2)
exp <- c(0, 1, 2+(1/6), 2+(3/6), 2+(5/6), 3+(2*1/10), 3+(2*3/10), 3+(2*5/10),
         3+(2*7/10), 3+(2*9/10), 7, 9+(1/4), 9+(3/4), 11)
verify.vectors(11.6, xq, exp)

xq <- midquantile(x, type=3)
exp <- c(0.5, 1.75, 2.75, 3.25, 3.75, 4.3, 4.9, 5.5, 6.1, 6.7, 8.25, 9.875,
         10.625, 11.5)
verify.vectors(11.7, xq, exp)

xq <- midquantile(x, type=4)
exp <- c(0, 2, 2+((2-1)/(3-1)), 3+(2*((3:6)-3)/(7-3)), 5+(4*((7:9)-7)/(10-7)),
         9+(((10:11)-10)/(11.5-10)), 10+(2*(12-11.5)/(13-11.5)), 12)
verify.vectors(11.8, xq, exp)

# Add ties at each end (even count start, odd end).
x <- c(0L, 0L, 2L, 3L, 3L, 3L, 5L, 5L, 5L, 5L, 5L, 9L, 10L, 10L, 12L, 12L, 12L)
nx <- length(x)
xuniq <- sort(unique(x))
nuniq <- length(xuniq)
xstep <- c(xuniq[1L], (xuniq[-1L]+xuniq[-nuniq])/2, xuniq[nuniq])
tied <- which(x[-1L]==x[-nx])
qID <- (-1:(nx-1))[-tied-1]

seg <- .Call('C_midq', x, 1L, 0.00, PACKAGE='Dimodal')
verify.vectors("12.1x", seg$x, xstep)
verify.vectors("12.1q", seg$q, qID/(nx-1))
seg <- .Call('C_midq', x, 2L, 0.00, PACKAGE='Dimodal')
verify.vectors("12.2x", seg$x, c(xuniq[1], xuniq))
verify.vectors("12.2q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 3L, 0.00, PACKAGE='Dimodal')
verify.vectors("12.3x", seg$x, xstep)
verify.vectors("12.3q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 4L, 0.00, PACKAGE='Dimodal')
verify.vectors("12.4x", seg$x, xuniq)
verify.vectors("12.4q", seg$q, c(0.5, 2, 4, 8, 11, 12.5, 15)/(nx-1))

xq <- midquantile(x, type=1)
exp <- c(1, 2, 5, 6, 7, 8, 9.2, 10.4, 11.6, 12.8, 14, 19, 20.5,
         22, 22+(2/3), 22+(4/3), 24) / 2
verify.vectors(12.5, xq, exp)

xq <- midquantile(x, type=2)
exp <- c(0, 0, 1, 2+(1/6), 2+(3/6), 2+(5/6), 3+(2*1/10), 3+(2*3/10),
         3+(2*5/10), 3+(2*7/10), 3+(2*9/10), 7, 9+(1/4), 9+(3/4),
         10+(2*1/6), 10+(2*3/6), 10+(2*5/6))
verify.vectors(12.6, xq, exp)

xq <- midquantile(x, type=3)
exp <- c(0.25, 0.75, 1.75, 2.75, 3.25, 3.75, 4.3, 4.9, 5.5, 6.1, 6.7, 8.25,
         9.875, 10.625, 11+(1/6), 11.5, 11+(5/6))
verify.vectors(12.7, xq, exp)

xq <- midquantile(x, type=4)
exp <- c(0, 0+(2*(1-0.5)/(2-0.5)), 2+(((2:3)-2)/(4-2)), 3+(2*((4:7)-4)/(8-4)),
         5+(4*((8:10)-8)/(11-8)), 9+(((11:12)-11)/(12.5-11)),
         10+(2*((13:14)-12.5)/(15-12.5)), 12, 12)
verify.vectors(12.8, xq, exp)

# Add ties at each end (odd count start, even end).
x <- c(0L, 0L, 0L, 2L, 3L, 3L, 3L, 5L, 5L, 5L, 5L, 5L, 9L, 10L, 10L, 12L, 12L)
nx <- length(x)
xuniq <- sort(unique(x))
nuniq <- length(xuniq)
xstep <- c(xuniq[1L], (xuniq[-1L]+xuniq[-nuniq])/2, xuniq[nuniq])
tied <- which(x[-1L]==x[-nx])
qID <- (-1:(nx-1))[-tied-1]

seg <- .Call('C_midq', x, 1L, 0.00, PACKAGE='Dimodal')
verify.vectors("13.1x", seg$x, xstep)
verify.vectors("13.1q", seg$q, qID/(nx-1))
seg <- .Call('C_midq', x, 2L, 0.00, PACKAGE='Dimodal')
verify.vectors("13.2x", seg$x, c(xuniq[1], xuniq))
verify.vectors("13.2q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 3L, 0.00, PACKAGE='Dimodal')
verify.vectors("13.3x", seg$x, xstep)
verify.vectors("13.3q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 4L, 0.00, PACKAGE='Dimodal')
verify.vectors("13.4x", seg$x, xuniq)
verify.vectors("13.4q", seg$q, c(1, 3, 5, 9, 12, 13.5, 15.5)/(nx-1))

xq <- midquantile(x, type=1)
exp <- c(2/3, 4/3, 2, 5, 6, 7, 8, 9.2, 10.4, 11.6, 12.8, 14, 19, 20.5,
         22, 23, 24) / 2
verify.vectors(13.5, xq, exp)

xq <- midquantile(x, type=2)
exp <- c(0, 0, 0, 1, 2+(1/6), 2+(3/6), 2+(5/6), 3+(2*1/10), 3+(2*3/10),
         3+(2*5/10), 3+(2*7/10), 3+(2*9/10), 7, 9+(1/4), 9+(3/4),
         10+(2*1/4), 10+(2*3/4))
verify.vectors(13.6, xq, exp)

xq <- midquantile(x, type=3)
exp <- c(1/6, 0.5, 5/6, 1.75, 2.75, 3.25, 3.75, 4.3, 4.9, 5.5, 6.1, 6.7, 8.25,
         9.875, 10.625, 11.25, 11.75)
verify.vectors(13.7, xq, exp)

xq <- midquantile(x, type=4)
exp <- c(0, 0+(2*((1:2)-1)/(3-1)), 2+(((3:4)-3)/(5-3)), 3+(2*((5:8)-5)/(9-5)),
         5+(4*((9:11)-9)/(12-9)), 9+(((12:13)-12)/(13.5-12)),
         10+(2*((14:15)-13.5)/(15.5-13.5)), 12)
verify.vectors(13.8, xq, exp)

# This is Dimodal test case 12.
x <- c(rep(1,5), rep(2,20), rep(6,10), rep(8,5), rep(10,10))
xperm <- sample(x, length(x))
nx <- length(x)
xuniq <- sort(unique(x))
nuniq <- length(xuniq)
xstep <- c(xuniq[1L], (xuniq[-1L]+xuniq[-nuniq])/2, xuniq[nuniq])
tied <- which(x[-1L]==x[-nx])
qID <- (-1:(nx-1))[-tied-1]

seg <- .Call('C_midq', x, 1L, 0.00, PACKAGE='Dimodal')
verify.vectors("14.1x", seg$x, xstep)
verify.vectors("14.1q", seg$q, qID/(nx-1))
seg <- .Call('C_midq', x, 2L, 0.00, PACKAGE='Dimodal')
verify.vectors("14.2x", seg$x, c(xuniq[1], xuniq))
verify.vectors("14.2q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 3L, 0.00, PACKAGE='Dimodal')
verify.vectors("14.3x", seg$x, xstep)
verify.vectors("14.3q", seg$q, (qID+0.5)/(nx-1))
seg <- .Call('C_midq', x, 4L, 0.00, PACKAGE='Dimodal')
verify.vectors("14.4x", seg$x, xuniq)
verify.vectors("14.4q", seg$q, c(2, 14.5, 29.5, 37, 44.5)/(nx-1))

xq <- midquantile(xperm, type=4)
exp <- c(rep(1, 2),
         1+(((2:14)-2)/(14.5-2)),
         2+(4*((15:29)-14.5)/(29.5-14.5)),
         6+(2*((30:36)-29.5)/(37-29.5)),
         8+(2*((37:44)-37)/(44.5-37)),
         rep(10, 5))
verify.vectors(14.8, xq, exp)

brk <- c(2, 14.5, 29.5, 37, 44.5)/49
#    = c(0.041, 0.296, 0.602, 0.755, 0.908).  Note dummy bin at first, last.
bin <- c(1, 1, 1, 2, 2, 2, 2, 3, 4, 4, 4)
exp <- sapply(seq_along(bin),
              function(i) {
                dx <- xuniq[bin[i]+1] - xuniq[bin[i]]
                dq <- brk[bin[i]+1] - brk[bin[i]]
                xuniq[bin[i]]+((dx * ((0.1*(i-1)) - brk[bin[i]])) / dq)
              })
exp[1] <- xuniq[1]
exp[length(exp)] <- xuniq[length(xuniq)]
xq <- midquantile(xperm, 0.1*(0:10), type=4)
verify.vectors(14.9, xq, exp)

xq <- midquantile(xperm, c(-Inf, -0.1, 0, NA, 0.3, NaN, 0.6, 1.0, 1.1, Inf),
                  type=4)
exp.btp <- c(rep(exp[1], 3), NA, exp[4], NaN, exp[7], rep(exp[11], 3))
verify.vectors("BTP14.10", xq, exp.btp)

verify.vectors("BTP14.11", midquantile(xperm, numeric(), type=4), numeric())

# Ramp.
x <- 1:50

xq <- midquantile(x, type=1)
exp <- x + 0.5 ; exp[50] <- 50
verify.vectors(15.1, xq, exp)

xq <- midquantile(x, type=2)
exp <- x - 0.5 ; exp[1] <- 1
verify.vectors(15.2, xq, exp)

xq <- midquantile(x, type=3)
exp <- x ; exp[1] <- 1.25 ; exp[50] <- 49.75
verify.vectors(15.3, xq, exp)

xq <- midquantile(x, type=4)
exp <- x
verify.vectors(15.4, xq, exp)

xq <- midquantile(x, c(-Inf, -0.1, 0, NA, 0.5, NaN, 1, 1.1, Inf), type=1)
exp.btp <- c(1, 1, 1.5, NA, 26, NaN, 50, 50, 50)
verify.vectors("BTP15.5", xq, exp.btp)

xq <- midquantile(x, c(-Inf, -0.1, 0, NA, 0.5, NaN, 1, 1.1, Inf), type=2)
exp.btp <- c(1, 1, 1, NA, 25, NaN, 49.5, 50, 50)
verify.vectors("BTP15.6", xq, exp.btp)

# Auto-choice of type.  The continuous data also checks that type 4
# does no interpolation.
x <- diff(tstds1)

xq <- midquantile(x, type=4)
exp <- sort(x)
verify.vectors(16.1, xq, exp)

xq <- midquantile(x, type=0)
exp <- sort(x)
verify.vectors(16.2, xq, exp)

x <- diff(sort(iris$Petal.Length))

xq <- midquantile(x, type=0)
exp <- midquantile(x, type=3)
verify.vectors(16.3, xq, exp)



Diopt(NULL)

if (allpass) {
  cat('  all utility tests PASSED\n')
}



