if ('faithful' %in% data()$results[,3]) {
  # No flats, ie. empty vector.
  m <- Dimodal(faithful$waiting, Diopt.local(diw.window=100))
  # Base result.
  exp.pos <- c(101, 227, 272)
  verify.vectors(6.01, m$diw.peaks$pos, exp.pos)
  verify.vectors(6.02, m$diw.flats$src, integer())
  verify.vectors(6.03, m$diw.flats$stID, integer())
  verify.vectors(6.04, m$diw.flats$endID, integer())
  # Centered.
  mc <- center.diw(m)
  verify.vectors(6.05, mc$diw.peaks$pos, exp.pos-50)
  verify.vectors(6.06, mc$diw.flats$src, integer())
  verify.vectors(6.07, mc$diw.flats$stID, integer())
  verify.vectors(6.08, mc$diw.flats$endID, integer())
  # Valid peak subset.
  verify.vectors(6.09, select.peaks(m$lp.peaks)$pos, c(98, 185))
  verify.vectors(6.10, select.peaks(m$diw.peaks)$pos, integer())
  # Feature matching.  No valid Diw peaks, nor flats.
  matched <- match.features(m, quiet=TRUE)
  exp.peak.lp2diw <- c(NA, NA)
  exp.peak.diw2lp <- integer()
  exp.flat.lp2diw <- c(NA)
  exp.flat.diw2lp <- integer()
  verify.vectors(6.11, matched$peak.lp2diw, exp.peak.lp2diw)
  verify.vectors(6.12, matched$peak.diw2lp, exp.peak.diw2lp)
  verify.vectors(6.13, matched$flat.lp2diw, exp.flat.lp2diw)
  verify.vectors(6.14, matched$flat.diw2lp, exp.flat.diw2lp)
}

