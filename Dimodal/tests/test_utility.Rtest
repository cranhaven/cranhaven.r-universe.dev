allpass <- TRUE
Diopt(analysis=c('lp', 'diw'))


## center.diw, select.peaks, match.features

# Test case 2 in test_find_[peaks|flats].
m <- Dimodal(tstds2, Diopt.local(diw.window=20, flat.fripple=0.02))
# Base result.
exp.pos <- c(21, 51, 142, 178, 224, 246, 278, 291, 300)
exp.src <- c(62, 142)
exp.stID <- c(49, 162)
exp.endID <- c(102, 204)
verify.vectors(1.01, m$diw.peaks$pos, exp.pos)
verify.vectors(1.02, m$diw.flats$src, exp.src)
verify.vectors(1.03, m$diw.flats$stID, exp.stID)
verify.vectors(1.04, m$diw.flats$endID, exp.endID)
# Centered.
mc <- center.diw(m)
verify.vectors(1.05, mc$diw.peaks$pos, exp.pos-10)
verify.vectors(1.06, mc$diw.flats$src, exp.src-10)
verify.vectors(1.07, mc$diw.flats$stID, exp.stID-10)
verify.vectors(1.08, mc$diw.flats$endID, exp.endID-10)
# Valid peak subset.
verify.vectors(1.09, select.peaks(m$lp.peaks)$pos, c(131, 221))
verify.vectors(1.10, select.peaks(m$diw.peaks)$pos, c(142, 224, 278))
# Feature matching.  No valid Diw peaks to match, no flats.
matched <- match.features(m, quiet=TRUE)
exp.peak.lp2diw <- rep(NA_integer_, 7) ; exp.peak.lp2diw[c(3,5)] <- c(3,5)
exp.peak.diw2lp <- rep(NA_integer_, 9) ; exp.peak.diw2lp[c(3,5)] <- c(3,5)
exp.flat.lp2diw <- integer()
exp.flat.diw2lp <- c(NA_integer_, NA_integer_)
verify.vectors(1.11, matched$peak.lp2diw, exp.peak.lp2diw)
verify.vectors(1.12, matched$peak.diw2lp, exp.peak.diw2lp)
verify.vectors(1.13, matched$flat.lp2diw, exp.flat.lp2diw)
verify.vectors(1.14, matched$flat.diw2lp, exp.flat.diw2lp)

