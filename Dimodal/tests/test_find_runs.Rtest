## Break the Part Tests

x <- c(NA_integer_, NA_integer_, NA_integer_)
verify.runs_discrete('BTP1', x)

x <- c(NA_real_, NA_real_, NaN, NaN)
verify.runs_real('BTP2', x, 0.025, NULL)

verify.error('BTP3', find.runs, list(c(1, 1, 1), -0.01))
verify.error('BTP4', find.runs, list(c(1, 1, 1), 1.01))
verify.error('BTP5', find.runs, list(c(2i+1, i+2, 3i), 0))
verify.error('BTP6', find.runs, list(vector(mode='integer', length=0), 0.001))
verify.error('BTP7', find.runs, list(vector(mode='real', length=0), 0.001))
verify.error('BTP8', find.runs, list(NULL, 0.001))


if (allpass) {
  cat('  all find.runs tests PASSED\n')
}
