##### Test Framework

# Compare the runs stored in Didata d against those in the C detector
# find.runs result r.  testID is added to any failure messages, which will
# also set the global allpass to FALSE.  Returns TRUE if the all checks pass.
verify.diwruns <- function(testID, d, r) {

  passed <- FALSE

  dsgn <- d['signed',]

  stID <- max(r$nskip[1], 1)

  if (!verify.runs_internal(testID, r)) {
    # Do nothing, failures already printed.
  } else if (stID != attr(d, 'diw.stID')) {
    cat('    test ', testID, ' run start at ', stID, ' not from signed diff ',
        attr(d,'diw.stID'), '\n')
  } else if ((1 < stID) && !all(is.na(dsgn[1:(stID-1)]))) {
    cat('    test ', testID, ' data before run start not NA\n')
  } else {
    rlsgn <- rle(dsgn[is.finite(dsgn)])$lengths
    rl <- r$runs[r$runs!=0]
    if (length(rlsgn) != length(rl)) {
      cat('    test ', testID, ' runs count ', length(rl), ' not rle count ',
          length(rlsgn), '\n')
    } else if (!all(rlsgn == rl)) {
      cat('    test ', testID, ' runs not match rle lengths\n')
    } else {
      passed <- TRUE
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Check that the find.runs result r is internally consistent.  Adds testID
# to failure messages, and also sets the global allpass to FALSE.  Returns
# TRUE If all checks pass.
verify.runs_internal <- function(testID, r) {

  passed <- TRUE

  # r$runs, r$nskip have length of original data.
  ndata <- length(r$runs)
  if (ndata != length(r$nskip)) {
    cat('    test ', testID, ' lengths differ, runs ', ndata,
        ' nskip ', length(r$nskip), '\n')
  } else if (ndata != (sum(r$runs) + sum(r$nskip))) {
    cat('    test ', testID, ' data length ', ndata,
        ' not sum runs ', sum(r$runs), ' and nskip ', sum(r$nskip), '\n')
  } else {
    # Note three cases here.
    #   A: runs[1] != 0, nskip[1] == 0  prev 1, next at (runs+nskip)[prev]
    #   B: runs[1] != 0, nskip[1] != 0  prev 1, next at (runs+nskip)[prev]
    #   C: runs[1] == 0, nskip[1] != 0  prev nskip+1, 
    #                                   next at runs+nskip if nskip+1 <= ndata
    if (0 == r$runs[1]) {
      iprev <- r$nskip[1] + 1
    } else {
      iprev <- 1
    }
    if (iprev <= ndata) {
      inext <- iprev + r$runs[iprev] + r$nskip[iprev]
    } else {
      inext <- ndata + 1
    }
    while (inext <= ndata) {
      if (0 == r$runs[inext]) {
        cat('    test ', testID, ' run from ', iprev, ' ends inside run\n')
        passed <- FALSE
        break
      } else if (((iprev + 1) < inext) &&
                 !all(0 == r$runs[(iprev+1):(inext-1)])) {
        cat('    test ', testID, ' skip from ', iprev+1, ' to ', inext-1,
            ' includes run\n')
        passed <- FALSE
        break
      }
      iprev <- inext
      inext <- inext + r$runs[inext] + r$nskip[inext]
    }
    if (ndata < inext) {
      passed <- TRUE
      if (r$stats['nrun'] != sum(r$runs!=0)) {
        cat('    test ', testID, ' has ', sum(r$runs!=0), ' runs, not nrun ',
            r$stats['nrun'], '\n')
        passed <- FALSE
      }
      if (r$stats['maxrun'] != max(r$runs)) {
        cat('    test ', testID, ' longest run ', max(r$runs), ' not maxrun ',
            r$stats['maxrun'], '\n')
        passed <- FALSE
      }
      if (r$stats['nx'] != ndata) {
        cat('    test ', testID, ' data length ', ndata, ' not nx ',
            r$stats['nx'], '\n')
        passed <- FALSE
      }
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Independent verification of find.runs on discrete data d.  testID added to
# failure error message, which also sets the global allpass to FALSE.
# Returns TRUE if find.runs is correct.
verify.runs_discrete <- function(testID, d) {

  passed <- TRUE

  r <- find.runs(d, 0)
  if (!verify.runs_internal(testID, r)) {
    passed <- FALSE
  } else {
    # Capture before deletion, b/c rle cannot handle bad values.
    ndata <- length(d)
    if (all(is.numeric(d))) {
      d <- d[is.finite(d)]
    } else {
      d <- d[!is.na(d)]
    }
    if (0 == length(d)) {
      rl <- c(0)
    } else {
      rl <- rle(d)$lengths
    }
    if (!all(rl == r$runs[r$runs!=0])) {
      cat('    test ', testID, ' runs do not match rle\n')
      passed <- FALSE
    }
    if (sum(rl!=0) != r$stats['nrun']) {
      cat('    test ', testID, ' runs count ', r$stats['nrun'],
          ' does not match rle ', sum(rl!=0), '\n')
      passed <- FALSE
    }
    if (max(rl) != r$stats['maxrun']) {
      cat('    test ', testID, ' longest run ', r$stats['maxrun'],
          ' does not match rle ', max(rl), '\n')
      passed <- FALSE
    }
    if (ndata != r$stats['nx']) {
      cat('    test ', testID, ' source data length ', r$stats['nx'],
          ' not actual ', ndata, '\n')
      passed <- FALSE
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Use find.runs on real data d with relative eps to consider values the same.
# Compare to the expected runs lengths rl.  testID added to failure error
# message.  Returns TRUE if find.runs is correct.
verify.runs_real <- function(testID, d, eps, rl) {

  passed <- TRUE

  r <- find.runs(d, eps)
  
  if (!verify.runs_internal(testID, r)) {
    passed <- FALSE
  } else {
    if (is.null(rl)) {
      if (0 != sum(r$runs)) {
        cat('    test ', testID, ' did not generate empty runs\n')
        passed <- FALSE
      }
      if ((0 != r$stats['nrun']) || (0 != r$stats['maxrun'])) {
        cat('    test ', testID, ' empty run stats not 0\n')
        passed <- FALSE
      }
    } else {
      if (!all(rl == r$runs[r$runs!=0])) {
        cat('    test ', testID, ' runs do not match expected\n')
        passed <- FALSE
      }
      # Note access via $nrun, while verify.runs_discrete tests ['nrun'].
      if (length(rl) != r$stats$nrun) {
        cat('    test ', testID, ' runs count ', r$stats$nrun,
            ' does not match expected ', length(rl), '\n')
        passed <- FALSE
      }
      if (max(rl) != r$stats$maxrun) {
        cat('    test ', testID, ' longest run ', r$stats$maxrun,
            ' does not match expected ', max(rl), '\n')
        passed <- FALSE
      }
      if (length(d) != r$stats$nx) {
        cat('    test ', testID, ' source data length ', r$stats$nx,
            ' not actual ', length(d), '\n')
        passed <- FALSE
      }
    }
  }
  
  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Taken from Dimodal, generate the default interval spacing and its signed
# difference for data x, upon which we will search for runs.  Returns a 5 row
# matrix with the raw data 'x', sorted 'xsort', spacing 'Di', interval spacing
# with an 0.10 window 'Diw', and signed difference 'signed'.  There are
# length(x) columns.  Also adds attributes to mock those created in Dimodal.
gen.data <- function(x) {

  xsrt <- sort(x)
  di <- c(NA, diff(xsrt))
  wdiw <- round(0.10 * length(x))
  diw <- c(rep(NA, wdiw), diff(xsrt, lag=wdiw))
  sdiw <- c(NA, sign(diff(diw)))

  m <- matrix(c(x, xsrt, di, diw, sdiw), nrow=5, byrow=TRUE,
              dimnames=list(c('x', 'xsort', 'Di', 'Diw', 'signed'), NULL))
  attributes(m) <- c(attributes(m),
                     list(diw.window=0.10, wdiw=wdiw, diw.stID=wdiw+1))
  m
}


