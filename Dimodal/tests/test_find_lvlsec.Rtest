source('../tests/test_common.Rtest')


##### Test Framework

# Compare the level sections lvlsec with their expected start and endpoints
# stID and endID.  testID is an identifier added to a failure message.
# Returns the pass/fail flag and also sets the global variable allpass to
# FALSE on any failure.
verify.lvlsec <- function(testID, lvlsec, stID, endID) {

  passed <- TRUE             

  if (length(stID) != length(endID)) {
    cat('    test ', testID, ' internal error: stID, endID lengths differ\n')
    allpass <<- FALSE
    return(FALSE)
  }
  if (length(stID) != nrow(lvlsec)) {
    cat('    test ', testID, ' level section count ', nrow(lvlsec),
        ' not expected ', length(stID))
    passed <- FALSE
  } else {
    if (any(lvlsec$stID != stID)) {
      cat('    test ', testID, ' mismatch start indices\n')
      cat('       expect ', stID, '\n')
      cat('       got    ', lvlsec$stID, '\n')
      passed <- FALSE
    }
    if (any(lvlsec$endID != endID)) {
      cat('    test ', testID, ' mismatch end indices\n')
      cat('       expect ', endID, '\n')
      cat('       got    ', lvlsec$endID, '\n')
      passed <- FALSE
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}


##### Test Cases

allpass <- TRUE

# Manually verified on meuse$cadmium, meuse$copper, acidity, enzyme against
# the modal.R result.

## Base tests also used in test_find_flats|peaks.

lvl <- find.level.sections(tstds1, 0.50, TRUE)
stID <-  c(   1,  31, 121, 177, 252, 300, 388, 461, 511, 593, 659)
endID <- c(  30, 139, 204, 274, 330, 417, 487, 542, 592, 683, 700)
