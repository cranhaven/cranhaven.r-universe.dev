## Constructed

set.seed(3)
pm <- 0.0225
f30 <- c(0, runif(29, -pm, +pm))
f50 <- c(0, runif(50, -pm, +pm))
ramp <- (0:50) * 0.02
# The two ramps put the centers of the flats at indices twice their mean value,
# ie. 0.25 -> 50, 0.50 -> 100, 0.75 -> 150.  The level sections are approx.
# 35-65, 85-115, and 135-165.  Actual values come from the development version
# and match.
x <- c(1-ramp, f30+0.50, f30+0.25, ramp, f30+0.75)
lvl <- find.level.sections(x, 0.5, TRUE)
stID <- c(   1,  23,  48,  79, 103, 133, 158)
endID <- c( 34,  60,  89, 114, 144, 170, 192)
verify.lvlsec(9, lvl, stID, endID)

# Here the flats are at the start and end of the sorted data, with 100
# points of ramps in-between.  We expect changepoints around 50 and 150.
x <- c(1-ramp, ramp, f50, f50+1.0)
lvl <- find.level.sections(x, 0.9, TRUE)
stID <- c(    1,  43, 150)
endID <- c(  55, 161, 204)
verify.lvlsec(10, lvl, stID, endID)


## Stress Tests

x <- rep(1.2, 50)
lvl <- find.level.sections(x, 0.5, TRUE)
stID <-  c(  1)
endID <- c( 50)
verify.lvlsec(11, lvl, stID, endID)

x <- rep(2L, 50)
lvl <- find.level.sections(x, 0.5, TRUE)
stID <-  c(  1)
endID <- c( 50)
verify.lvlsec(12, lvl, stID, endID)

x <- 0.01 * (0:100)
lvl <- find.level.sections(x, 0.25, TRUE)
stID <-  c(   1)
endID <- c( 101)
verify.lvlsec(13, lvl, stID, endID)

diw <- diff(x, lag=16)
lvl <- find.level.sections(diw, 0.25, TRUE)
stID <-  c(  1,  9, 14, 29, 44)
endID <- c( 10, 13, 28, 43, 85)
verify.lvlsec(14, lvl, stID, endID)

lvl <- find.level.sections(diff(x, lag=16), 0.5, TRUE)
stID <-  c(  1,  8, 14, 29, 44)
endID <- c( 10, 13, 28, 43, 85)
verify.lvlsec(15, lvl, stID, endID)

x <- rep(c(0.5, 1.5), 25)
lvl <- find.level.sections(x, 0.5, TRUE)
stID <-  c(  1, 26)
endID <- c( 25, 50)
verify.lvlsec(16, lvl, stID, endID)

x <- matrix(diw, nrow=5, byrow=FALSE)
lvl <- find.level.sections(x, 0.25, TRUE)
stID <-  c(  1,  9, 14, 29, 44)
endID <- c( 10, 13, 28, 43, 85)
verify.lvlsec(17, lvl, stID, endID)

x <- c(rep(4.0, 15), 0.2*(0:25), rep(2.4, 20))
lvl <- find.level.sections(x, 0.5, FALSE)
stID <-  c(  1, 13, 32, 41)
endID <- c( 15, 32, 43, 61)
verify.lvlsec(18, lvl, stID, endID)

x.na <- c(rep(NA_real_, 5), x)
lvl <- find.level.sections(x.na, 0.5, FALSE)
stID <-  c(  1, 13, 32, 41) + 5
endID <- c( 15, 32, 43, 61) + 5
verify.lvlsec(19, lvl, stID, endID)

x.na <- c(x, rep(NA_real_, 3))
lvl <- find.level.sections(x.na, 0.5, FALSE)
stID <-  c(  1, 13, 32, 41)
endID <- c( 15, 32, 43, 61) 
verify.lvlsec(20, lvl, stID, endID)

x.na <- c(x[1:20], NA, NA, x[21:40], NA, x[41:length(x)])
lvl <- find.level.sections(x.na, 0.5, FALSE)
stID <-  c(  1, 13, 34, 44)
endID <- c( 15, 34, 46, 64) 
verify.lvlsec(21, lvl, stID, endID)

x.na <- c(NA, NA, NA, x.na, NA)
lvl <- find.level.sections(x.na, 0.5, FALSE)
stID <-  c(  1, 13, 34, 44) + 3
endID <- c( 15, 34, 46, 64) + 3
verify.lvlsec(22, lvl, stID, endID)

x.nan <- c(rep(NaN, 5), x)
lvl <- find.level.sections(x.nan, 0.5, FALSE)
stID <-  c(  1, 13, 32, 41) + 5
endID <- c( 15, 32, 43, 61) + 5
verify.lvlsec(23, lvl, stID, endID)

x.nan <- c(x, NaN, NaN)
lvl <- find.level.sections(x.nan, 0.5, FALSE)
stID <-  c(  1, 13, 32, 41)
endID <- c( 15, 32, 43, 61)
verify.lvlsec(24, lvl, stID, endID)

x.nan <- c(x[1:14], NaN, x[15:32], NaN, NaN, NaN, x[33:50], NaN,
           x[51:length(x)])
lvl <- find.level.sections(x.nan, 0.5, FALSE)
stID <-  c(  1, 13, 33, 45)
endID <- c( 16, 33, 47, 66)
verify.lvlsec(25, lvl, stID, endID)

x.nan <- c(NaN, x.nan, NaN, NaN)
lvl <- find.level.sections(x.nan, 0.5, FALSE)
stID <-  c(  1, 13, 33, 45) + 1
endID <- c( 16, 33, 47, 66) + 1
verify.lvlsec(26, lvl, stID, endID)



## Break The Part Tests

x <- rep(NA_real_, 30)
verify.error('BTP1', find.level.sections, list(x, 0.5, TRUE))

x <- rep(NA_integer_, 40)
verify.error('BTP2', find.level.sections, list(x, 0.25, TRUE))

x <- NULL
verify.error('BTP3', find.level.sections, list(x, 0.25, TRUE))

x <- numeric(0)
verify.error('BTP4', find.level.sections, list(x, 0.25, TRUE))

x <- c(1.1)
verify.error('BTP5', find.level.sections, list(x, 0.25, TRUE))

x <- c(1.1, 1.1)
verify.error('BTP6', find.level.sections, list(x, 0.25, TRUE))

x <- c(1.1, 2.1)
verify.error('BTP7', find.level.sections, list(x, 0.25, TRUE))

verify.error('BTP8', find.level.sections, list(x.nan, -0.01, TRUE))
verify.error('BTP9', find.level.sections, list(x.nan, 1.01, TRUE))
verify.error('BTP10', find.level.sections, list(x.nan, 0.5, 'a'))
verify.error('BTP11', find.level.sections, list(x.nan, 'a', TRUE))
verify.error('BTP12', find.level.sections, list(x.nan, 0, TRUE))
verify.error('BTP13', find.level.sections, list(x.nan, 1, TRUE))
verify.error('BTP14', find.level.sections, list(as.complex(x.nan), 0.5, TRUE))


if (allpass) {
  cat('  all find.lvlsec tests PASSED\n')
}
