if (interactive()) {
  source('../R/Diopt.R')
  source('../R/Dimodal.R')
  source('../R/methods.R')
  source('../R/detectors.R')
  source('../R/sigtests.R')
  source('../R/cpt.R')
  source('../R/Ditrack.R')
  source('../R/utility.R')

  if (is.loaded('C_find_peaks', PACKAGE='Dimodal')) {
    dyn.unload('../src/Dimodal.so')
  }
  dyn.load('../src/Dimodal.so')
} else {
  load(Dimodal)
}

source('../tests/test_common.Rtest')



