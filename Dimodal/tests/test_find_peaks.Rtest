## BTP test cases.

verify.error('BTP1', find.peaks, list(x, -0.01,  0.15,  0.001, 0.9))
verify.error('BTP2', find.peaks, list(x,  1.01,  0.15,  0.001, 0.9))
verify.error('BTP3', find.peaks, list(x,  1L,  0.15,  0.001, 0.9))
verify.error('BTP4', find.peaks, list(x,  0.05, -0.01,  0.001, 0.9))
verify.error('BTP5', find.peaks, list(x,  0.05,  1.01,  0.001, 0.9))
verify.error('BTP6', find.peaks, list(x,  0.05,  1L,  0.001, 0.9))
verify.error('BTP7', find.peaks, list(x,  0.05,  0.15, -0.01, 0.9))
verify.error('BTP8', find.peaks, list(x,  0.05,  0.15,  1.01, 0.9))
verify.error('BTP9', find.peaks, list(x,  0.05,  0.15,  1L, 0.9))
verify.error('BTP10', find.peaks, list(rep(TRUE, 5), 0.05, 0.15, 0.001, 0.9))
verify.error('BTP11', find.peaks, list(x, 0.05,  0.15,  0.001, -0.01))
verify.error('BTP12', find.peaks, list(x, 0.05,  0.15,  0.001,  1.01))

verify.empty('BTP13', find.peaks, list(rep(1,50), 0.05, 0.05, 0.001, 0.9))
verify.empty('BTP14', find.peaks, list(c(1), 0.05, 0.05, 0.001, 0.9))
verify.empty('BTP15', find.peaks, list(c(1, 1), 0.05, 0.05, 0.001, 0.9))
verify.empty('BTP16', find.peaks,
             list((1:50)[-(1:50)], 0.05, 0.05, 0.001, 0.9))
verify.empty('BTP17', find.peaks,
             list(rep(NA_real_,50), 0.05, 0.05, 0.001, 0.9))
verify.empty('BTP18', find.peaks, list(NULL, 0.05, 0.05, 0.001, 0.9))
# Differs from BTP13 b/c small floating point differences.
diw <- diff(0.01*(0:100), lag=16)
verify.empty('BTP19', find.peaks, list(diw, 0.05, 0.05, 0.001, 0.9))


if (allpass) {
  cat('  all find.peaks tests PASSED\n')
}

