## To Do:
# -
#


if (interactive()) {
  source('../R/Diopt.R')
  source('../R/Dimodal.R')
  source('../R/methods.R')
  source('../R/detectors.R')
  source('../R/sigtests.R')
  source('../R/cpt.R')
  source('../R/Ditrack.R')

  if (is.loaded('C_find_peaks', PACKAGE='Dimodal')) {
    dyn.unload('../src/Dimodal.so')
  }
  dyn.load('../src/Dimodal.so')
} else {
  library(Dimodal)
}

source('../tests/test_common.Rtest')


# We don't check the results, just that the tracks work for all window sizes
# in both the low-pass and interval spacing.  We ignore any warnings about
# small window sizes.

verify.noerror(1.1, Ditrack, list(tstds1, 'lp'))
verify.noerror(1.2, Ditrack, list(tstds1, 'diw'))

verify.noerror(2.1, Ditrack, list(tstds2, 'lp'))
verify.noerror(2.2, Ditrack, list(tstds2, 'diw'))

verify.noerror(3.1, Ditrack, list(tstds3, 'lp'))
verify.noerror(3.2, Ditrack, list(tstds3, 'diw'))

verify.noerror(4.1, Ditrack, list(tstds4, 'lp'))
verify.noerror(4.2, Ditrack, list(tstds4, 'diw'))

verify.noerror(5.1, Ditrack, list(faithful$eruptions, 'lp'))
verify.noerror(5.2, Ditrack, list(faithful$eruptions, 'diw'))

verify.noerror(6.1, Ditrack, list(faithful$waiting, 'lp'))
verify.noerror(6.1, Ditrack, list(faithful$waiting, 'diw'))

verify.noerror(7.1, Ditrack, list(iris$Petal.Length, 'lp'))
verify.noerror(7.1, Ditrack, list(iris$Petal.Length, 'diw'))

verify.noerror(8.1, Ditrack, list(iris$Petal.Width, 'lp'))
verify.noerror(8.1, Ditrack, list(iris$Petal.Width, 'diw'))

verify.noerror(9.1, Ditrack, list(quakes[,3], 'lp'))
verify.noerror(9.1, Ditrack, list(quakes[,3], 'diw'))

verify.noerror(10.1, Ditrack, list(chickwts$weight, 'lp'))
verify.noerror(10.1, Ditrack, list(chickwts$weight, 'diw'))


if (allpass) {
  cat('  all Ditrack tests PASSED\n')
}
