##### Test Framework - Diopt specific

# Test that two lists are the same = have the same number of members and
# that each value is the same.  If not print a failure message including
# an identifier testID.  Value comparison based on Diopt - not a generic
# list comparator.  Sets the global allpass to FALSE on failure.
# Returns TRUE if the two lists match.
verify.optlists <- function(testID, l1, l2) {

  passed <- FALSE
  if (length(l1) != length(l2)) {
    cat('    test ', testID, ' failed - length mismatch ',
        length(l1), ' ', length(l2), '\n')
  } else if (!setequal(names(l1), names(l2))) {
    cat('    test ', testID, ' failed - name mismatch ',
        setdiff(names(l1), names(l2)), '\n')
  } else {
    pass <- sapply(seq_along(l1),
                   function(i) {
                     tag <- names(l1)[i]
                     verify.option(tag, l1[[i]], l2[[tag]])
                   })
    if (!all(pass)) {
      for (i in which(!pass)) {
        tag <- names(l1)[[i]]
        cat('    test ', testID, ' failed - ', tag, ' ', l1[[tag]],
            ' != ', l2[[tag]], '\n')
      }
    } else {
      passed <- TRUE
    }
  }
  
  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# If vs.dflt TRUE, test that all tag=value pairs in lpairs match the values
# in the default Diopt.  If FALSE, test that all current Diopt values match
# lpairs or, if not present, the default.  Failure messages include the
# identifier testID.  Sets the global allpass to FALSE on failure.  Returns
# TRUE if all comparisons succeed.
verify.Diopt <- function(testID, lpairs, vs.dflt=FALSE) {

  passed <- FALSE

  if (vs.dflt) {
    curropt <- lpairs
    lpairs <- NULL
  } else {
    curropt <- Diopt()
  }

  pass <- sapply(seq_along(curropt),
                 function(i) {
                   tag <- names(curropt)[i]
                   if (tag %in% names(lpairs)) {
                     verify.option(tag, curropt[[tag]], lpairs[[tag]])
                   } else {
                     verify.option(tag, curropt[[tag]], diopt.dflt[[tag]])
                   }
                 })
  
  if (!all(pass)) {
    for (i in which(!pass)) {
      tag <- names(curropt)[i]
      if (tag %in% names(lpairs)) {
        val1 <- lpairs[[tag]]
      } else {
        val1 <- diopt.dflt[[tag]]
      }
      if (is.list(curropt) || is.list(val1)) {
        cat('    test ', testID, ' failed - ', tag, '\n')
        if (is.list(curropt)) {
          cat('      actual ') ; print(curropt[[tag]])
        } else {
          cat('      actual ', curropt[[tag]], '\n')
        }
        if (is.list(val1)) {
          cat('      expect ') ; print(val1)
        } else {
          cat('      expect ', val1, '\n')
        }
      } else {
        cat('    test ', testID, ' failed - ', tag, ' ', curropt[[tag]],
            ' != ', val1, '\n')
      }
    }
  } else {
    passed <- TRUE
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Return TRUE if the two values val1, val2 for option tag match.
verify.option <- function(tag, val1, val2) {

  switch(tag,
         analysis=(setequal(val1, val2)),
         data.midq=(val1==val2),
         lp.kernel=(val1==val2),
         lp.window=nearly(val1, val2),
         lp.tests=(setequal(val1, val2)),
         lp.param=(setequal(val1, val2) &&
                   setequal(names(val1), names(val2))),
         diw.window=nearly(val1, val2),
         diw.tests=(setequal(val1, val2)),
         diw.param=(setequal(val1, val2) &&
                    setequal(names(val1), names(val2))),
         peak.fht=nearly(val1, val2),
         peak.frelht=nearly(val1, val2),
         peak.fhtie=nearly(val1, val2),
         peak.fhsupp=nearly(val1, val2),
         flat.fripple=nearly(val1, val2),
         flat.minlen=nearly(val1, val2),
         flat.fminlen=nearly(val1, val2),
         flat.noutlier=nearly(val1, val2),
         flat.distrib=(val1==val2),
         excur.nrep=nearly(val1, val2),
         excur.ntop=nearly(val1, val2),
         excur.seed=nearly(val1, val2),
         perm.nrep=nearly(val1, val2),
         perm.seed=nearly(val1, val2),
         alpha.ht=nearly(val1, val2),
         alpha.pkexcur.lp=nearly(val1, val2),
         alpha.pkexcur.diw=nearly(val1, val2),
         alpha.len=nearly(val1, val2),
         alpha.ftexcur.lp=nearly(val1, val2),
         alpha.ftexcur.diw=nearly(val1, val2),
         alpha.runht=nearly(val1, val2),
         alpha.nrun=nearly(val1, val2),
         alpha.runlen=nearly(val1, val2),
         cpt.libs=(setequal(val1, val2)),
         cpt.fncpt.max=nearly(val1, val2),
         cpt.qvote=nearly(val1[1], val2[1]) && nearly(val1[2], val2[2]),
         cpt.fsep=nearly(val1, val2),
         cpt.sep=nearly(val1, val2),
         cpt.libsep=nearly(val1, val2),
         cpt.timeout=nearly(val1, val2),
         track.maxwindow=nearly(val1, val2),
         palette=(val1==val2),
         colID.data=(val1==val2),
         colID.filter=(val1==val2),
         colID.hist=(val1==val2),
         colID.cdf=(val1==val2),
         colID.peak=(val1==val2),
         colID.flat=(val1==val2),
         colID.cpt=(val1==val2),
         mark.alpha=!xor(val1, val2),
         mark.flat=(val1==val2),
         digits=nearly(val1, val2),
         FALSE) 
}

# Check that the element names of the two lists l1, l2 are the same.
# Returns TRUE if so, if not prints a failure message with testID as an
# identifier and sets the global variable allpass to FALSE.
verify.names <- function(testID, l1, l2) {

  n1 <- sort(names(l1))
  n2 <- sort(names(l2))

  passed <- TRUE

  if (length(n1) != length(n2)) {
    cat('    test ', testID, ' number of names differ, n1 ',
        length(n1), '  n2 ', length(n2), '\n')
    passed <- FALSE
  } else if (!all(n1 == n2)) {
    cat('    test ', testID, ' option names differ\n')
    passed <- FALSE
  }
  if (!passed) {
    cat('      n1: ', n1, '\n')
    cat('      n2: ', n2, '\n')
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}


##### Test Bench

allpass <- TRUE


## General changes.

# Test 1: Start in default state.
verify.optlists(1, Diopt(), diopt.dflt)

# Test 2: Change lp/diw entries to valid values.  Note completion of filter.
new <- list(lp.kernel='Hann', lp.window=0.9, lp.tests=c('ht', 'FTexcur'),
            diw.window=0.3, diw.tests=c('runht', 'ruNLen', 'nrun'))
exp <- new
exp$lp.kernel <- 'hanning'
exp$lp.tests <- c('ht', 'ftexcur')
exp$diw.tests <- c('runht', 'runlen', 'nrun')
old <- do.call('Diopt', new)
verify.names(2.1, old, new)
verify.Diopt(2.2, exp)
verify.Diopt(2.3, old, TRUE)
chng <- do.call('Diopt', as.list(names(new)))
verify.lists(2.4, exp, chng)
# Must reset or comparisons in next test against defaults will fail.
Diopt(NULL)
verify.optlists(2.5, Diopt(), diopt.dflt)
# Verify equivalent behavior when arguments wrapped in list.
old <- do.call('Diopt', list(new))
verify.names(2.6, old, new)
verify.Diopt(2.7, exp)
verify.Diopt(2.8, old, TRUE)
chng <- do.call('Diopt', as.list(names(new)))
verify.lists(2.9, exp, chng)
Diopt(NULL)

