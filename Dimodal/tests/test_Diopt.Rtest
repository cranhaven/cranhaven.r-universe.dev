new <- list(cpt.qvote=c(0.75, 0.25))
old <- do.call('Diopt', new)
verify.optlists('BTP9.1', Diopt(), diopt.dflt)
verify.lists('BTP9.2', old, NULL)
verify.names('BTP9.3', old, new)

# BTP10: Other parameters.
new <- list(track.maxwindow=1.01)
old <- do.call('Diopt', new)
verify.optlists('BTP10.1', Diopt(), diopt.dflt)
verify.lists('BTP10.2', old, NULL)
verify.names('BTP10.3', old, new)

new <- list(track.maxwindow=-1)
old <- do.call('Diopt', new)
verify.optlists('BTP10.4', Diopt(), diopt.dflt)
verify.lists('BTP10.5', old, NULL)
verify.names('BTP10.6', old, new)

# BTP11: Color IDs.
new <- list(colID.data=-1, colID.filter=0, colID.hist=0.4, colID.cdf=8.6,
            colID.peak=9, colID.flat=9.9, colID.cpt=-0.1)
old <- do.call('Diopt', new)
verify.optlists('BTP11.1', Diopt(), diopt.dflt)
verify.lists('BTP11.2', old, NULL)
verify.names('BTP11.3', old, new)

# BTP12: Palette.
new <- list(palette='Something Blue')
old <- do.call('Diopt', new)
verify.optlists('BTP12.1', Diopt(), diopt.dflt)
verify.lists('BTP12.2', old, NULL)
verify.names('BTP12.3', old, new)

new <- list(palette='hcl:Something Blue')
old <- do.call('Diopt', new)
verify.optlists('BTP12.4', Diopt(), diopt.dflt)
verify.lists('BTP12.5', old, NULL)
verify.names('BTP12.6', old, new)

new <- list(palette='hcl.Yl(Or)Rd,')
old <- do.call('Diopt', new)
verify.optlists('BTP12.7', Diopt(), diopt.dflt)
verify.lists('BTP12.8', old, NULL)
verify.names('BTP12.9', old, new)

# BTP13: Other display options.
new <- list(mark.alpha='twue', digits=-1, mark.flat='boxy')
old <- do.call('Diopt', new)
verify.optlists('BTP13.1', Diopt(), diopt.dflt)
verify.lists('BTP13.2', old, NULL)
verify.lists('BTP13.3', old, new)

# BTP14: Alternate invalid display options.
new <- list(mark.alpha=NA, digits=9.2, mark.flat=NA)
old <- do.call('Diopt', new)
verify.optlists('BTP14.1', Diopt(), diopt.dflt)
verify.lists('BTP14.2', old, NULL)
verify.lists('BTP14.3', old, new)

# BTP15: Data preparation.
new <- list(data.midq=-1)
old <- do.call('Diopt', new)
verify.optlists('BTP15.1', Diopt(), diopt.dflt)
verify.lists('BTP15.2', old, NULL)
verify.lists('BTP15.3', old, new)
new <- list(data.midq=5)
old <- do.call('Diopt', new)
verify.optlists('BTP15.4', Diopt(), diopt.dflt)
verify.lists('BTP15.5', old, NULL)
verify.lists('BTP15.6', old, new)

# BTP16: Warning for non-existent option.
verify.warning('BTP16.1', Diopt, list('peak_frelht'=0))
verify.warning('BTP16.2', Diopt, list(list('lp.filter'='kaiser')))

# BTP17: Example from man page.
Diopt(NULL)
Diopt(Diopt(cpt.qvote=c(0.45,0.55), peak.fht=0.15))
verify.optlists('BTP17', Diopt(), diopt.dflt)

 
Diopt(NULL)


if (allpass) {
  cat('  all Diopt tests PASSED\n')
}
