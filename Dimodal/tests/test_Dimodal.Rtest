# Full analysis.
set.seed(5)
x <- c(rnorm(90, -2.25, 1.25), rnorm(60, -0.75, 0.2),
       rnorm(90,  2.25, 1.25), rnorm(60,  0.75, 0.2))
Diopt(analysis=c('lp','diw'), flat.minlen=20, excur.seed=7, perm.seed=3,
      lp.param=list(peak.fhsupp=1.0), excur.ntop=10)
m <- Dimodal(x)
exp.pk <- data.frame(pos=c(61, 151),
                     ht=c(2.694, 2.431),
                     hexcur=c(0.0325, 0.0294),
                     pht=c(0.00486, 0.0127),
                     pexcur=c(0.000, 0.000),
                     ppeak=c(0.000, 0.000),
                     naccept=c(2, 1))
verify.peaks(15.1, m$lp.peaks, exp.pk)
exp.ft <- data.frame(stID=c(94, 177, 222),
                     endID=c(126, 197, 241),
                     len=c(33, 21, 20),
                     hexcur=c(0.00229, 0.00209, 0.00214),
                     plen=c(0.5258, 0.6983, 0.7126),
                     pexcur=c(0.001, 0.014, 0.022),
                     pflat=c(0.001, 0.014, 0.022),
                     naccept=c(1, 0, 0))
verify.flats(15.2, m$lp.flats, exp.ft)
exp.pk <- data.frame(pos=c(76, 166, 250, 299),
                     hexcur=c(0.9585, 0.8159, 0.6223, 0.5146),
                     nrun=c(32, 26, 26, 16),
                     runlen=c(8,12,14,15),
                     runht=c(28, 22, 20, 16),
                     pexcur=c(0.0024, 0.0060, 0.0351, 0.0674),
                     pnrun=c(0.0355, 0.0061, 0.5445, 0.0854),
                     prunlen=c(0.1915, 0.0340, 0.0089, 0.0039),
                     prunht=c(0.0116, 0.0000, 0.0384, 0.5968),
                     ppeak=c(0.0039, 0.0002, 0.0089, 0.0039),
                     naccept=c(1, 3, 2, 1))
verify.peaks(15.3, m$diw.peaks, exp.pk)
exp.ft <- data.frame(stID=c(105, 155, 191),
                     endID=c(145, 174, 214),
                     hexcur=c(0.0939, 0.0767, 0.0647),
                     pexcur=c(0.000, 0.0041, 0.0001),
                     pflat=c(0.000, 0.0041, 0.0001),
                     naccept=c(1, 1, 1))
verify.flats(15.4, m$diw.flats, exp.ft)
Diopt(NULL)

set.seed(3)
x <- c(rnorm(120, 0.211, sqrt(0.012)), rnorm(60, 0.75, sqrt(0.062)),
       rbeta(80,5,2))
Diopt(analysis=c('lp', 'diw'), excur.seed=7, perm.seed=12, alpha.runht=0.04,
      excur.ntop=10)
m <- Dimodal(x)
exp.pk <- data.frame(pos=c(139, 177),
                     ht=c(2.907, 1.794),
                     hexcur=c(0.00436, 0.00271),
                     pht=c(0.00415, 0.1060),
                     pexcur=c(0.0013, 0.0203),
                     ppeak=c(0.0013, 0.0203),
                     naccept=c(2, 1))
verify.peaks(16.1, m$lp.peaks, exp.pk)
exp.ft <- data.frame(stID=25, endID=110, len=86, hexcur=0.000358,
                     plen=0.0212, pexcur=0.000, pflat=0.000, naccept=2)
verify.flats(16.2, m$lp.flats, exp.ft)
exp.pk <- data.frame(pos=c(148, 186),
                     hexcur=c(0.1357, 0.0782),
                     nrun=c(52, 10),
                     runlen=c(8, 14),
                     runht=c(19, 14),
                     pexcur=c(0.0788, 0.1943),
                     pnrun=c(0.7139, 0.0007),
                     prunlen=c(0.1904, 0.0031),
                     prunht=c(0.0063, 0.0863),
                     ppeak=c(0.0063, 0.0007),
                     naccept=c(1, 2))
verify.peaks(16.3, m$diw.peaks, exp.pk)
exp.ft <- data.frame(stID=33, endID=125, hexcur=0.0218,
                     pexcur=0.0000, pflat=0.0000, naccept=1)
verify.flats(16.4, m$diw.flats, exp.ft)
# Check all attributes added by Dimodal outside gen.data.
verify.lists(16.5, attributes(m$lp.peaks)["source"], list(source="LP"))
verify.lists(16.6, attributes(m$lp.flats)["source"], list(source="LP"))
verify.lists(16.7, attributes(m$diw.peaks)["source"], list(source="Diw"))
verify.lists(16.8, attributes(m$diw.flats)["source"], list(source="Diw"))
exp.attr <- list(lp.kernel="kaiser", lp.window=0.15, wlp=39,
                 lp.stID=21, lp.endID=241,
                 diw.window=0.10, wdiw=26, diw.stID=27,
                 data.name="x")
verify.lists(16.9, attributes(m$data)[names(exp.attr)], exp.attr)
Diopt(NULL)


## Broken Examples Fixed During Debugging

x <- iris$Petal.Length
# This generated negative draw sizes for the LP excursion.
Diopt(analysis='lp')
verify.noerror(17, Dimodal,
               list(x, opt=Diopt.local(lp.window=0.02, lp.tests='pkexcur')))



## Break-the-Part and Stress Tests

x <- iris$Petal.Length

Diopt(analysis='lp')
verify.basedata('BTP data1', x, 'lp',
                list(data.midq=4, lp.window=0.01, lp.kernel='kaiser'))
verify.basedata('BTP data2', x, 'lp',
                list(data.midq=4, lp.window=1, lp.kernel='kaiser'))
verify.basedata('BTP data3', x, 'lp',
                list(data.midq=4, lp.window=2, lp.kernel='kaiser'))
verify.error('BTP data4', gen.data, 
             list(x, 'lp', list(data.midq=4, lp.window=0.10, lp.kernel='rectangular')))
verify.basedata('BTP data5', x, 'lp',
                list(data.midq=4, lp.window=190, lp.kernel='kaiser'))

Diopt(analysis='lp')
verify.basedata('BTP data6', x, 'diw', list(data.midq=4, diw.window=0.0025))
verify.basedata('BTP data7', x, 'diw', list(data.midq=4, diw.window=190))

Diopt(analysis=c('lp', 'diw'))
verify.error('BTP 1', Dimodal, list(rep('a', 50)))
verify.error('BTP 2', Dimodal, list(rep(20i, 50)))
verify.error('BTP 3', Dimodal, list(NULL))
verify.warning('BTP 4', Dimodal, list(rep(NA_real_, 50)))
verify.warning('BTP 5', Dimodal, list(c(1,3,1,3,1,3)))

Diopt(NULL)
Diopt(lp.tests=NULL, diw.tests=NULL, analysis=c('lp', 'diw'))
m <- Dimodal(tstds1)
verify.empty('BTP 6 LP peak', m$lp.peaks)
verify.empty('BTP 6 Diw peak', m$diw.peaks)
verify.empty('BTP 6 LP flat', m$lp.flats)
