  mockup.Diflat <- Dimodal:::mockup.Diflat
  mockup.Dicpt <- Dimodal:::mockup.Dicpt
}

source('../tests/test_common.Rtest')


##### Test Framework

# Check that the positions of the peaks and flats in the two Dimodal result
# m against a list pos of positions, with elements named the same as in m
# set as matrices with columns 'pos', 'ismax' for peaks or 'stID', 'endID'
# for flats.  Have a 0 row matrix, b.v. from mockup.Di*, if there are no
# results.  Cover if TRUE means that flats in m must lie within the range
# of a flat in pos.  Returns whether the feature positions are correct.  If
# any fail, use testID in the failure message and set the global allpass FALSE.
verify.pos <- function(testID, m,  pos, cover=FALSE) {

  passed <- TRUE

  for (i in c('lp.peaks', 'diw.peaks')) {
    if (is.null(pos[[i]]) && (0 != nrow(m[[i]]))) {
      cat('    ', testID, ' expected no ', i, ' but in Dimodal result\n')
      passed <- FALSE
    } else if (!is.null(pos[[i]])) {
      if (nrow(pos[[i]]) != nrow(m[[i]])) {
        cat('    ', testID, ' expected ', nrow(pos[[i]]), i,
            ' but Dimodal has ', nrow(m[[i]]), '\n')
        passed <- FALSE
      } else {
        if (!verify.vectors(paste0(testID, ' ', i, '/pos'),
                            m[[i]][,'pos'], pos[[i]][,'pos'])) {
          passed <- FALSE
        }
      }
    }
  }

  for (i in c('lp.flats', 'diw.flats')) {
    if (is.null(pos[[i]]) && (0 != nrow(m[[i]]))) {
      cat('    ', testID, ' expected no ', i, ' but in Dimodal result\n')
      passed <- FALSE
    } else if (!is.null(pos[[i]])) {
      if (nrow(pos[[i]]) != nrow(m[[i]])) {
        cat('    ', testID, ' expected ', nrow(pos[[i]]), i,
            ' but Dimodal has ', nrow(m[[i]]), '\n')
        passed <- FALSE
      } else {
        if (cover) {
          outside <- (m[[i]][,'stID'] < pos[[i]][,'stID']) |
                     (pos[[i]][,'endID'] < m[[i]][,'endID'])
          if (any(outside)) {
            cat('    ', testID, i, ' flats ', which(outside),
                ' lie outside expected\n')
            passed <- FALSE
          }
        } else {
          for (j in c('stID', 'endID')) {
            if (!verify.vectors(paste0(testID, ' ', i, '/', j),
                                m[[i]][,j], pos[[i]][,j])) {
              passed <- FALSE
            }
          }
        }
      }
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Test that gen.data applied to data x and filter method ('lp' or 'diw')
# _only_ creates the base values: sorted x, mid-distribution function, and
# spacing.  opt is a list that need only contain the parameters for the
# filter, [lp|diw].window and lp.kernel.  gen.data must generate a warning
# for the bad setup or the test fails.  Returns whether all checks pass, and
# if not sets the global variable allpass to FALSE.  testID is an identifier
# used in failure messages.
verify.basedata <- function(testID, x, method, opt) {

  passed <- TRUE

  if (!verify.warning(testID, gen.data, list(x, method, opt))) {
    passed <- FALSE
  }
  
  d <- suppressWarnings(gen.data(x, method, opt))
  if ((4 != nrow(d)) ||
      (0 < length(setdiff(rownames(d), c('x', 'xsort', 'xmid', 'Di'))))) {
    cat('    test ', testID, ' did not generate only base data (spacing, xmid)')
    passed <- FALSE
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Yet another test for peaks, this time looking at the common subset of data
# frames pk1 and pk2.  If the columns $ismax and $ppeak appear in the frame,
# then only valid maxima are used for the comparison if screen is TRUE.
# Rather loose accuracy on probabilities and and other values.  Returns
# whether the two match or FALSE if not, in which case the global variable
# allpass is also set to FALSE.  testID is an identifier used in failure
# messages.
verify.peaks <- function(testID, pk1, pk2, screen=TRUE) {

  passed <- TRUE

  if (screen && ('ismax' %in% names(pk1)) && ('ppeak' %in% names(pk1))) {
    pk1 <- pk1[pk1$ismax & !is.na(pk1$ppeak),]
  }
  if (screen && ('ismax' %in% names(pk2)) && ('ppeak' %in% names(pk2))) {
    pk2 <- pk2[pk2$ismax & !is.na(pk2$ppeak),]
  }

  cols1 <- colnames(pk1)
  cols2 <- colnames(pk2)
  if (nrow(pk1) != nrow(pk2)) {
    cat('    test ', testID, ' mismatch in number of peaks: ',
        nrow(pk1), ' vs. ', nrow(pk2), '\n')
    passed <- FALSE
  } else {
    for (i in intersect(cols1, cols2)) {
      if ('pos' == i) {
        eps <- 0
      } else if ('p' == substr(i,1,1)) {
        eps <- 0.005
      } else {
        eps <- 0.01
      }
      if (!all(nearly(pk1[[i]], pk2[[i]], eps))) {
        cat('    test ', paste0(testID, ' ', i), ' values differ\n')
        cat('      pk1 ', pk1[[i]], '\n')
        cat('      pk2 ', pk2[[i]], '\n')
        passed <- FALSE
      }
    }
    if (('ht' %in% cols1) && ('lht' %in% cols2) && ('rht' %in% cols2)) {
      ht2 <- pmax(pk2[['lht']], pk2[['rht']])
      if (!all(nearly(pk1[['ht']], ht2, 0.01))) {
        cat('    test ', paste0(testID, ' ht'), ' values differ\n')
        cat('      pk1 ', pk1[['ht']], '\n')
        cat('      pk2 ', ht2, '\n')
        passed <- FALSE
      }
    } else if (('lht' %in% cols1) && ('rht' %in% cols1) && ('ht' %in% cols2)) {
      ht1 <- pmax(pk1[['lht']], pk1[['rht']])
      if (!all(nearly(ht1, pk2[['ht']], 0.01))) {
        cat('    test ', paste0(testID, ' ht'), ' values differ\n')
        cat('      pk1 ', ht1, '\n')
        cat('      pk2 ', pk2[['ht']], '\n')
        passed <- FALSE
      }
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Yet another test for flats, this time looking at the common subset of both
# data frames ft1 and ft2.  Rather loose accuracy on probabilities and and
# other values.  Returns whether the two match or FALSE if not, in which case
# the global variable allpass is also set to FALSE.  testID is an identifier
# used in failure messages.
verify.flats <- function(testID, ft1, ft2) {

  passed <- TRUE

  if (nrow(ft1) != nrow(ft2)) {
    cat('    test ', testID, ' mismatch in number of flats: ',
        nrow(ft1), ' vs. ', nrow(ft2), '\n')
    passed <- FALSE
  } else {
    for (i in intersect(colnames(ft1), colnames(ft2))) {
      if (('stID' == i) || ('endID' == i) || ('len' == i)) {
        eps <- 0
      } else if ('p' == substr(i,1,1)) {
        eps <- 0.001
      } else {
        eps <- 0.01
      }
      if (!all(nearly(ft1[[i]], ft2[[i]], eps))) {
        cat('    test ', paste0(testID, ' ', i), ' values differ\n')
        cat('      ft1 ', ft1[[i]], '\n')
        cat('      ft2 ', ft2[[i]], '\n')
        passed <- FALSE
      }
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Check that the data frame/matrix d has no rows but the same columns as
# Dipeak/Diflat/Dicpt/Didata.  Returns TRUE if so, or FALSE if the data is
# not empty.  On failure the global variable allpass is also set to FALSE.
# testID is an identifier used in the failure messages.
verify.empty <- function(testID, d) {

  passed <- TRUE
  
  if ('Dipeak' %in% class(d)) {
    if (0 != nrow(d)) {
      cat('    test ', testID, ' fails because data not empty\n')
      passed <- FALSE
    } else if (0 != length(setdiff(colnames(d), colnames(mockup.Dipeak())))) {
      cat('    test ', testID, ' fails for column mis-match\n')
      passed <- FALSE
    }
  } else if ('Diflat' %in% class(d)) {
    if (0 != nrow(d)) {
      cat('    test ', testID, ' fails because data not empty\n')
      passed <- FALSE
    } else if (0 != length(setdiff(colnames(d), colnames(mockup.Diflat())))) {
      cat('    test ', testID, ' fails for column mis-match\n')
      passed <- FALSE
    }
  } else if ('Dicpt' %in% class(d)) {
    if (0 != nrow(d)) {
      cat('    test ', testID, ' fails because data not empty\n')
      passed <- FALSE
    } else if (0 != length(setdiff(names(d), names(mockup.Dicpt())))) {
      cat('    test ', testID, ' fails for element mis-match\n')
      passed <- FALSE
    }
  } else if ('Didata' %in% class(d)) {
    if (0 != nrow(d)) {
      cat('    test ', testID, ' fails because data not empty\n')
      passed <- FALSE
    } else if (0 != length(setdiff(colnames(d), colnames(mockup.Didata())))) {
      cat('    test ', testID, ' fails for column mis-match\n')
      passed <- FALSE
    }
  } else {
    cat('    test ', testID, ' internal failure - unknown data format\n')
    passed <- FALSE
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Create a Dipeaks results with one row per element in pos/ismax and the
# positions and maximum flags set.  All other columns will be NA.
set.peakpos <- function(pos, ismax) {

  if (length(pos) != length(ismax)) {
    stop('internal error - argument lengths differ')
  }

  pk <- mockup.Dipeak()
  # Grow the right number of rows.
  pk[length(pos),'pos'] <- pos[length(pos)]
  pk$pos <- pos
  pk$ismax <- ismax
  
  pk
}

# Create a Diflats results with one row per element in stID/endID and the
# endpoints and lengths set.  All other columns will be NA.
set.flatpos <- function(stID, endID) {

  if (length(stID) != length(endID)) {
    stop('internal error - endpoint lengths differ')
  }

  flt <- mockup.Diflat()
  flt[length(stID),'stID'] <- stID[length(stID)]
  flt$stID <- stID
  flt$endID <- endID
  flt$len <- endID - stID + 1
  
  flt
}


