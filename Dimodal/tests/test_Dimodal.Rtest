## Constructed Examples

Diopt(analysis=c('lp', 'diw'))

# Constant spacing = no peaks, one flat spanning Di/Diw
m <- Dimodal(0.01*(0:100))
a <- attributes(m$data)
exp <- list(lp.peaks=mockup.Dipeak(),
            lp.flats=set.flatpos(a$lp.stID, a$lp.endID),
            diw.peaks=mockup.Dipeak(),
            diw.flats=set.flatpos(a$diw.stID, ncol(m$data)))
verify.pos(8, m, exp)

# Constant increase = extrema at Di/Diw ends, no flats
m <- Dimodal(0.001*((0:100)^2))
a <- attributes(m$data)
exp <- list(lp.peaks=set.peakpos(c(a$lp.stID, a$lp.endID), c(FALSE, TRUE)),
            lp.flats=mockup.Diflat(),
            diw.peaks=set.peakpos(c(a$diw.stID, ncol(m$data)), c(FALSE, TRUE)),
            diw.flats=mockup.Diflat())
verify.pos(9, m, exp)

# Sigmoid = peak at center, no flats
x <- gen.pwl(c(0,1,0), 0.02)$x
m <- Dimodal(cumsum(x))
a <- attributes(m$data)
exp <- list(lp.peaks=set.peakpos(c(a$lp.stID, 51, a$lp.endID),
                                 c(FALSE, TRUE, FALSE)),
            lp.flats=mockup.Diflat(),
            diw.peaks=set.peakpos(c(a$diw.stID, 51+(a$wdiw/2), ncol(m$data)),
                                  c(FALSE, TRUE, FALSE)),
            diw.flats=mockup.Diflat())
verify.pos(10, m, exp)

set.seed(5)
x <- c(x[1:16], x[16]*(1.0+0.0025*runif(50,-1,1)),
       x[17:66], x[66]*(1.0+0.0025*runif(60,-1,1)),
       x[67:length(x)])
m <- Dimodal(cumsum(x), opt=Diopt.local(flat.fripple=0.01, flat.minlen=20))
a <- attributes(m$data)
# The filter round the flat so we don't match endpoints exactly.
# Endpoints taken from Di, Diw +/- 1% about x[16],x[66].  The peaks just
# shift by the first flat length.
exp <- list(lp.peaks=set.peakpos(c(a$lp.stID, 51+50, a$lp.endID),
                                 c(FALSE, TRUE, FALSE)),
            lp.flats=set.flatpos(c(16,116), c(66,176)),
            diw.peaks=set.peakpos(c(a$diw.stID, 51+50+floor(a$wdiw/2),
                                    ncol(m$data)),
                                 c(FALSE, TRUE, FALSE)),
            diw.flats=set.flatpos(c(34,133), c(68,179)))
verify.pos(11, m, exp, cover=TRUE)

xsrt <- c(rep(1,5), rep(2,20), rep(6,10), rep(8,5), rep(10,10))
x <- sample(xsrt, length(xsrt))
d <- gen.data(x, 'diw', list(data.midq=4, diw.window=6))
# See utility test case 14.
exp.xmid <- c(rep(1, 2),
              1+(((2:14)-2)/(14.5-2)), 2+(4*((15:29)-14.5)/(29.5-14.5)),
              6+(2*((30:36)-29.5)/(37-29.5)), 8+(2*((37:44)-37)/(44.5-37)),
              rep(10, 5))
exp.di <- c(NA, rep(0,4), 1,rep(0,19), 4,rep(0,9), 2,rep(0,4), 2,rep(0,9))
exp.diw <- c(rep(NA,6), rep(1,5), rep(0,14), rep(4,6), rep(0,4),
             rep(2,5), 4, rep(2,5),rep(0,4))
exp.sgn <- c(rep(NA,7), rep(0,4), -1,rep(0,13), 1,rep(0,5), -1,rep(0,3),
             1,rep(0,4), 1,-1,rep(0,4), -1,rep(0,3))
exp.attr <- list(diw.window=6, wdiw=6, diw.stID=7)
verify.vectors(12.1, d['x',], x)
verify.vectors(12.2, d['xsort',], xsrt)
verify.vectors(12.3, d['Di',], exp.di)
verify.vectors(12.4, d['Diw',], exp.diw)
verify.vectors(12.5, d['signed',], exp.sgn)
verify.vectors(12.6, d['xmid',], exp.xmid)
verify.lists(12.7, attributes(d)[names(exp.attr)], exp.attr)

x <- iris$Petal.Length
# Ignore the model range warning (flp too small).
m <- suppressWarnings(Dimodal(iris$Petal.Length, 
                              Diopt.local(analysis='lp',
                                          lp.window=3, peak.fht=0.1)))
exp.pk <- data.frame(pos=c(51, 54, 147),
                     lht=c(10.33, 1.14, 2.07),
                     rht=c(9.67, 1.81, 1.67),
                     pht=c(0.000, 0.265, 0.234))
verify.peaks(13.1, m$lp.peaks, exp.pk)
exp.ft <- data.frame(stID=6, endID=37, len=32, plen=0.04186)
verify.flats(13.2, m$lp.flats, exp.ft)
m <- suppressWarnings(Dimodal(iris$Petal.Length, 
                      Diopt.local(analysis='diw',
                                  diw.window=3, peak.fht=0.2)))
exp.pk <- data.frame(pos=c(53, 147),
                     lht=c(6.85, 2.45),
                     rht=c(6.85, 0.98))
verify.peaks(13.3, m$diw.peaks, exp.pk)
exp.ft <- mockup.Diflat()[,c('stID','endID','len')]
verify.flats(13.4, m$diw.flats, exp.ft)

x <- iris$Petal.Length
m <- suppressWarnings(Dimodal(iris$Petal.Length, 
                              Diopt.local(analysis='lp',
                                          lp.window=length(x)-3)))
