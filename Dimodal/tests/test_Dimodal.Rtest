                     pht=c(NA, NA, NA))
verify.peaks(14.1, m$lp.peaks, exp.pk, screen=FALSE)
exp.ft <- mockup.Diflat()[,c('stID','endID','len')]
verify.flats(14.2, m$lp.flats, exp.ft)
m <- suppressWarnings(Dimodal(iris$Petal.Length, 
                              Diopt.local(analysis='diw',
                                          diw.window=length(x)-3)))
