## BTP and edge case tests.

# Flat at start.  Flat gets shorter with successive sources, first longest.
set.seed(2)
x <- sort(c(runif(50, 0.49,0.51), rep(c(1,2), 25)))
exp <- make.flats(x, 0.05, src=1, stID=1, endID=50)
compare.flats('BTP1', exp, find.flats(x, 0.05, 30, 0.05, 1))

# Flat after single outlier.
x <- c(1, x)
exp <- make.flats(x, 0.05, src=2, stID=2, endID=51)
compare.flats('BTP2', exp, find.flats(x, 0.05, 30, 0.05, 1))

# Flat after double outlier.
x <- c(1, x)
exp <- make.flats(x, 0.05, src=3, stID=3, endID=52)
compare.flats('BTP3', exp, find.flats(x, 0.05, 30, 0.05, 1))

# Flat at end.
set.seed(2)
x <- sort(c(rep(c(-1,0), 25), runif(50, 0.49,0.51)))
exp <- make.flats(x, 0.05, src=51, stID=51, endID=100)
compare.flats('BTP4', exp, find.flats(x, 0.05, 30, 0.05, 1))

# Flat with single outlier at end.
x <- c(x, -1)
exp <- make.flats(x, 0.05, src=51, stID=51, endID=100)
compare.flats('BTP5', exp, find.flats(x, 0.05, 30, 0.05, 1))

# Flat with double outlier at end.
x <- c(x, -1)
exp <- make.flats(x, 0.05, src=51, stID=51, endID=100)
compare.flats('BTP6', exp, find.flats(x, 0.05, 30, 0.05, 1))

# No flats.
exp <- make.flats(x, 0.05, src=1, stID=1,endID=2)[-1L,]
compare.flats('BTP7', exp, find.flats(rep(c(0,1),50), 0.05, 30, 0.05, 1))

# Start setup but no flat, short by one.
set.seed(2)
x <- sort(c(runif(29, 0.49,0.51), rep(c(1,2), 25)))
compare.flats('BTP8', exp, find.flats(x, 0.05, 30, 0.05, 1))

# End setup but no flat, short by one.
set.seed(2)
x <- sort(c(rep(c(-1,0), 25), runif(29, 0.49,0.51)))
compare.flats('BTP9', exp, find.flats(x, 0.05, 30, 0.05, 1))

# Bad parameters.
verify.error('BTP10a', find.flats, list(x, -0.1, 20, 0.05, 1))
verify.error('BTP10b', find.flats, list(x,  1.1, 20, 0.05, 1))
verify.error('BTP11a', find.flats, list(x, 0.05, 0.49, 0.05, 1)) # Rounds to 0
verify.error('BTP11b', find.flats, list(x, 0.05, -20, 0.05, 1))
verify.error('BTP12a', find.flats, list(x, 0.05, 20, -0.1, 1))
verify.error('BTP12b', find.flats, list(x, 0.05, 20,  1.1, 1))
verify.error('BTP13',  find.flats, list(x, 0.05, 20, 0.05, -1))
verify.empty('BTP14',  find.flats, list(NULL, 0.05, 20, 0.02, 1))
verify.empty('BTP15',  find.flats, list(vector('numeric',0), 0.05, 20, 0.02, 1))
verify.empty('BTP16',  find.flats, list(c(1.01), 0.05, 20, 0.02, 1))

# Unsupported value type.
verify.error('BTP17a',find.flats, list(rep(NA_logical_, 30), 0.05, 20, 0.05, 1))
verify.error('BTP17b',find.flats, list(rep(NA_complex_, 30), 0.05, 20, 0.05, 1))


if (allpass) {
  cat('  all find.flat tests PASSED\n')
}


