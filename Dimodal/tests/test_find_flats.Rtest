## Constructed data.

# f## is a sequence ## long with max range 0.045, ie. flat with ripple 0.05.
# r## has max range 0.60 and is outside the ripple spec.
# s## is a spacer of 0 and 1 setting the range.  f and r may be shifted by
# +/- 0.4 without running outside the spacer.
set.seed(3)
pm <- 0.0225
# Putting 0.5 as the first value means it will source the whole flat.
f25 <- 0.5 + c(0, runif(24, -pm, +pm))
f29 <- 0.5 + c(0, runif(28, -pm, +pm))
f30 <- 0.5 + c(0, runif(29, -pm, +pm))
f31 <- 0.5 + c(0, runif(30, -pm, +pm))
f35 <- 0.5 + c(0, runif(34, -pm, +pm))
f45 <- 0.5 + c(0, runif(44, -pm, +pm))
r25 <- f25 * 0.6 / diff(range(f25))
r29 <- f29 * 0.6 / diff(range(f29))
r30 <- f30 * 0.6 / diff(range(f30))
r31 <- f31 * 0.6 / diff(range(f31))
r35 <- f35 * 0.6 / diff(range(f35))
s10 <- rep(c(0,1), 5)

x <- c(s10, f29, s10, f30, s10, f31, s10)
exp <- make.flats(x, 0.05,
                  src=c(   50, 90),
                  stID=c(  50, 90),
                  endID=c( 79, 120))
compare.flats('8 (scan)', exp, find.flats.ver(x, 0.05, 30, 0.05, 1, ver=1L))
compare.flats('8 (walk)', exp, find.flats.ver(x, 0.05, 30, 0.05, 1, ver=2L))

# Rougher segments do not pass.
x <- c(s10, r29, s10, f30, s10, r30, s10, r31, s10)
exp <- make.flats(x, 0.05,
                  src=c(   50),
                  stID=c(  50),
                  endID=c( 79))
compare.flats('9 (scan)', exp, find.flats.ver(x, 0.05, 30, 0.05, 1, ver=1L))
compare.flats('9 (walk)', exp, find.flats.ver(x, 0.05, 30, 0.05, 1, ver=2L))

x <- c(s10, f30, s10, f31, s10, f35, s10)
# Outliers to each side; the point after to 0.5 sources the flat.
x[c(12,39, 52,80, 93,125)] <- 1
x[c(13, 53, 94)] <- 0.5
exp <- make.flats(x, 0.05,
                  src=c(   13, 53, 94),
                  stID=c(  11, 51, 92),
                  endID=c( 40, 81, 126))
compare.flats('10 (scan)', exp, find.flats.ver(x, 0.05, 30, 0.05, 1, ver=1L))
compare.flats('10 (walk)', exp, find.flats.ver(x, 0.05, 30, 0.05, 1, ver=2L))

