##### Test Framework

# Variant of the actual find.flats that exposes the version argument, to
# force the algorithm.  Prefer to pass the version as an integer.
find.flats.ver <- function(x, fripple=eval(formals(find.flats)[['fripple']]),
                           minlen=eval(formals(find.flats)[['minlen']]),
                           fminlen=eval(formals(find.flats)[['fminlen']]),
                           noutlier=eval(formals(find.flats)[['noutlier']]),
                           ver=0L) {
  as.data.frame(
    .Call('C_find_flats', x, fripple, minlen, fminlen, noutlier, ver,
          PACKAGE='Dimodal')
  )
}

# Return a flat data frame based on the source/seed data point src, endpoints
# stID and endID (incl.), standardized height htsd, and standard deviation of
# the data stdev.  Calculates length and raw height.  If src or stID or endID
# are NULL or 0 length vectors, the data frame will be empty (0 rows) but
# have the correct number of columns.
make.flats <- function(x, fripple, src, stID, endID) {

  if ((0 == length(src)) || (0 == length(stID)) || (0 == length(endID))) {
    v0 <- numeric(0)
    return(data.frame(src=v0, stID=v0, endID=v0, len=v0, srcval=v0, ht=v0, htsd=v0))
  }

  src <- as.integer(src)
  stID <- as.integer(stID)
  endID <- as.integer(endID)

  xfin <- x[is.finite(x)]
  dx <- diff(range(xfin))
  if ((dx / fripple) < mean(xfin)) {
    sigma <- 1
  } else {
    sigma <- sd(xfin)
  }

  ripple <- fripple * dx / 2
  ht <- sapply(seq_along(src),
               function(i) {
                 xlo <- x[src[i]] - ripple
                 xhi <- x[src[i]] + ripple
                 xflat <- x[stID[i]:endID[i]]
                 xflat <- xflat[(xlo <= xflat) & (xflat <= xhi)]
                 diff(range(xflat[is.finite(xflat)]))
               })
  data.frame(src=src, stID=stID, endID=endID, len=endID-stID+1,
             srcval=x[src], ht=ht, htsd=ht/sigma)
}

# Check that the contents of two flat results are the same.  Print mismatches
# with a test identifier testID.  Return a pass/fail flag and sets the global
# allpass to FALSE on failure.
compare.flats <- function(testID, flt1, flt2) {

  if ((nrow(flt1) != nrow(flt2)) || (ncol(flt1) != ncol(flt2))) {
    cat('    test ', testID, ' results incompatible: ',
        dim(flt1), ' vs. ', dim(flt2), '\n')
    cat('flat v1:\n')
    print.data.frame(flt1)
    cat('flat v2:\n')
    print.data.frame(flt2)
    allpass <<- FALSE
    return(FALSE)
  }

  # Do this column by column to separate integers from reals.
  cols <- c('src', 'stID', 'endID', 'len', 'srcval', 'ht', 'htsd')
  pass <- sapply(cols, function(c) { nearly(flt1[,c], flt2[,c], 0.001) })
  if (any(!pass)) {                 
    cat('    test ', testID, ' results differ   by flat # (vals)\n')
    for (i in which(!pass)) {
      cat('      ', cols[i], ': ')
      for (j in which(0.001 < abs(flt1[,cols[i]] - flt2[,cols[i]]))) {
        cat(sprintf(' %2d (%7.4f, %7.4f)', j, flt1[j,cols[i]], flt2[j,cols[i]]))
      }
      cat('\n')
    }
    allpass <<- FALSE
  }

  all(pass)
}

# Comparison of the two flat versions for several datasets and smoothing
# variations, allowing noutlier points outside the ripple spec to each
# side of the flat's source.  Failure prints an error message.  Returns TRUE
# if all tests pass, FALSE if any fail.
compare.ver <- function(noutlier=1) {

  data(meuse, package='sp')
  data(acidity, package='multimode')
  data(enzyme, package='multimode')
  data(galaxy, package='multimode')

  xall <- list(meuse$cadmium, meuse$copper, acidity, enzyme, galaxy)
  dsnames <- c('cadmium', 'copper', 'acidity', 'enzyme', 'galaxy')

  cat('\ntesting flat scan (v1) vs. tree walk (v2)\n')
  for (i in seq_along(xall)) {
    for (w in c(4, 8, 16, 24, 32)) {
      testID <- sprintf('%s w=%d', dsnames[i], w)
      diw <- diff(sort(xall[[i]]), lag=w)
      fltv1 <- tryCatch({ find.flats.ver(diw, 0.05, 20, 0.05, noutlier, 1L) },
                        error=function(e) {
                                cat('    test ', testID, ' v1 error:\n')
                                print(e)
                                NULL
                              })
      fltv2 <- tryCatch({ find.flats.ver(diw, 0.05, 20, 0.05, noutlier, 2L) },
                        error=function(e) {
                                cat('    test ', testID, ' v2 error:\n')
                                print(e)
                                NULL
                              })
      if (is.null(fltv1) || is.null(fltv2) ||
          !compare.flats(testID, fltv1, fltv2)) {
        passed <- FALSE
      }
    }
  }

  passed
}

# Compare the flat algorithms on large amounts of data - the asteroid
# distribution.  For many large sample sizes (multiplied by mult) of the
# asteroids' axis, calculate the interval spacing with interval w and run
# both the scan and tree flat detectors.  Allow noutlier points outside
# the ripple spec per flat.  Compare the results for equality,
# printing mismatches, and gather the timing of each.  Returns a matrix
# with the sample size in thousands and the times in seconds for v1 (scan)
# and v2.  This will take a long time to run - 30 minutes for the v1 and 11
# for v2.
compare.timing <- function(sizes=c(1, 5, 10, 25, 50, 100, 150, 200, 250,
                                   300, 400, 500, 750),
                           mult=1000, w=100, noutlier=1) {

  if (any(w >= (sizes*mult))) {
    stop('interval width larger than smallest sample size')
  }

  astorb <- readRDS('/devel/stats/modal/ex/kirkwood/astorb.rds')
  a <- astorb$axis[astorb$axis < 5.0]

  passed <- TRUE
  tv <- sapply(sizes,
               function(nx) {
                 set.seed(nx)
                 diw <- diff(sort(sample(a, mult*nx)), lag=w)
                 t1 <- Sys.time()
                 fltv1 <- find.flats.ver(diw, 0.05, 20, 0.05, noutlier, 1L)
                 t2 <- Sys.time()
                 fltv2 <- find.flats.ver(diw, 0.05, 20, 0.05, noutlier, 2L)
                 t3 <- Sys.time()

                 if (!compare.flats(sprintf('axis nx=%d', nx), fltv1, fltv2)) {
                   passed <<- FALSE
                 }

                 c(nx=mult*nx,
                   v1=as.numeric(difftime(t2, t1, units='s')),
                   v2=as.numeric(difftime(t3, t2, units='s')))
              })

  if (!passed) {
    cat('\ntiming/verification of flat searches in asteroid distribution\n')
    cat('  some subsets DIFFER\n')
  }

  t(tv)
}


##### Manual Test Cases

# Manually verified on Diw w=16 of meuse$cadmium, meuse$copper, acidity,
# enzyme, galaxy against the model.R result (meuse from package sp, the others
# from multimode).  htsd and aspect ratio changed (devel version is WRONG,
