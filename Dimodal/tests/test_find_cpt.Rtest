# lib9     20    40    60    80    100    120    140    160    180   200

# Note if even number of libraries voting, half is majority.
# 0.2,0.9  T8    T4    no    T5     no     T6     no     T7     no    T8
# 0.3,0.8  T6    T3    no    T4     no     T5     no     T6     no    T6
# 0.2,0.8  T7    no    no    T4     no     T5     no     T6     no    T7
