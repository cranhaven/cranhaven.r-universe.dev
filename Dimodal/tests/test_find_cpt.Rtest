# 0.5,0.7  T5    T3    no    T4     no     T5     no     T5     no    T5
# -> 5,7 -> 4,8 = 0.4,0.8
# 0.6,0.8  T5    T4    no    T5     no     T5     T3     T5     no    T5
# -> 0.5,0.9

x <- unlist( lapply(1:11, rep, 20) )
rawpts <- list(which(diff(x) != 0))
rawpts <- list(c(100),
               c(20, 201),
               c(19, 157, 199),
               c(21, 119, 163, 203),
               c(23, 79, 123, 159, 204),
               c(17, 39, 81, 117, 161, 201),
               c(16, 42, 76, 116, 141, 162, 197),
               c(24, 38, 84, 124, 139, 158, 179, 196),
               c(20, 40, 60, 80, 120, 140, 160, 180, 199),
               c(20, 40, 60, 80, 100, 120, 140, 160, 180, 200))
test <- data.frame(library=sprintf('lib%d', (1:length(rawpts))-1),
                   detector=sprintf('detect%d', (1:length(rawpts))-1),
                   abbrev=sprintf('det%d', (1:length(rawpts))-1),
                   ncpt=sapply(rawpts, length))
