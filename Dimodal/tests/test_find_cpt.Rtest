source('../tests/test_common.Rtest')


##### Test Framework - find.cpt specific

# Check that the merged library points, the libraries used in voting, and
# the checkpoint locations match between the two Dicpt objects cpt1, cpt2.
# Returns whether all checks pass, and sets the global allpass to FALSE if
# any fail.  testID is a test case identifier used in failure messages.
verify.cpt <- function(testID, cpt1, cpt2) {

  passed <- TRUE

  if (!is.null(cpt1$voting) && !is.null(cpt2$voting) &&
      (0 < length(setdiff(cpt1$voting, cpt2$voting)))) {
    cat('    test ', testID, ' voting libraries differ\n')
    cat('      cpt1: ', cpt1$voting, '\n')
    cat('      cpt2: ', cpt2$voting, '\n')
    passed <- FALSE
  }

  if (!is.null(cpt1$libpts) && !is.null(cpt2$libpts)) {
    if (0 < length(setdiff(names(cpt1$libpts), names(cpt2$libpts)))) {
      cat('    test ', testID, ' library point names differ\n')
      passed <- FALSE
    } else {
      for (i in names(cpt1$libpts)) {
        txt <- paste0(testID, ' ', i)
        if (!verify.vectors(txt, cpt1$libpts[i], cpt2$libpts[i])) {
          passed <- FALSE
        }
      }
    }
  }

  if (!is.null(cpt1$cpt) && !is.null(cpt2$cpt)) {
    for (i in c('pos', 'val', 'nvote')) {
      if ((i %in% colnames(cpt1$cpt)) && (i %in% colnames(cpt2$cpt))) {
        txt <- paste0(testID, ' cpt ', i)
        passed <- passed & verify.vectors(txt, cpt1$cpt[,i], cpt2$cpt[,i])
      }
    }
  }

  if (!is.null(cpt1$cptparam) && !is.null(cpt2$cptparam)) {
    if (0 != length(setdiff(names(cpt1$cptparam), names(cpt2$cptparam)))) {
      cat('    test ', testID, ' cpt parameter lists differ\n')
      cat('      cpt1: ', names(cpt1$cptparam), '\n')
      cat('      cpt2: ', names(cpt2$cptparam), '\n')
      passed <- FALSE
    } else {
      for (i in names(cpt1$cptparam)) {
        if (!nearly(cpt1$cptparam[[i]], cpt2$cptparam[[i]])) {
          cat('    test ', testID, ' cpt parameter ', i, ' values differ')
          if (length(cpt1$cptparam[[i]]) <= 2) {
            cat('  ', cpt1$cptparam[[i]], ' v. ', cpt2$cptparam[[i]], '\n')
          } else {
            cat('\n      cpt1: ', cpt1$cptparam[[i]], '\n')
            cat('      cpt2: ', cpt2$cptparam[[i]], '\n')
          }
          passed <- FALSE
        }
      }
    }
  }

  if (!passed) {
    allpass <<- FALSE
  }
  passed
}

# Mock up the Dicpt element cptparam.  libsep, sep, fsep, qvote are the
# merge.cpt arguments/options, rawres the mocked result of identify.cpt,
# and npt the number of points per library.
set.cptparam <- function(libsep, sep, fsep, qvote, rawres, npt) {

  ncpt <- rawres$test$ncpt
  near <- min(sep, round(fsep * rawres$rawparam$nx))
  qpts <- round(quantile(npt, qvote, names=FALSE, type=4))
  minvote <- max(1, sum((qpts[1] <= npt) & (npt <= qpts[2])) / 2)
  
  list(libsep=libsep, sep=sep, fsep=fsep, qvote=qvote,
       near=near, qpts=qpts, minvote=minvote)
}


##### Test Bench

