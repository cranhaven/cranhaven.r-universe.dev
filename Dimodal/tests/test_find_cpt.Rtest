## Break-the-part tests.

x <- c(1)
rawpts <- list(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL)
test <- data.frame(library=sprintf('lib%d', 1:length(rawpts)),
                   detector=sprintf('detect%d', 1:length(rawpts)),
                   abbrev=sprintf('lib%ddet', 1:length(rawpts)),
                   ncpt=sapply(rawpts, length))
rawparam <- list(cptlibs='dummy', maxfncpt=0.10, ncpt=16, timeout=2, nx=1)
res <- list(test=test, rawpts=rawpts, rawparam=rawparam)

lpt <- rawpts ; names(lpt) <- sprintf('lib%d', 1:length(lpt))
npt <- sapply(lpt, length)
prm <- list(libsep=2, sep=4, fsep=0.15, qvote=c(0.1,0.9))
vote <- names(lpt)
exp <- list(libpts=lpt, voting=vote, cptparam=NULL, cpt=cbind(pos=double()))
res2 <- merge.cpt(res, x, prm$qvote, prm$sep, prm$fsep, prm$libsep)
verify.cpt('BTP 1', res2, exp)

x <- c(rep(1,10), rep(2,10))
rawpts <- list(NULL, c(9), NULL, c(10), NULL, c(19), NULL)
test <- data.frame(library=sprintf('lib%d', 1:length(rawpts)),
                   detector=sprintf('detect%d', 1:length(rawpts)),
                   abbrev=sprintf('lib%ddet', 1:length(rawpts)),
                   ncpt=sapply(rawpts, length))
rawparam <- list(cptlibs='all', maxfncpt=0.10, ncpt=16, timeout=2, nx=length(x))
res <- list(test=test, rawpts=rawpts, rawparam=rawparam)

lpt <- rawpts ; names(lpt) <- sprintf('lib%d', 1:length(lpt))
npt <- sapply(lpt, length)
prm <- list(libsep=2, sep=4, fsep=0.15, qvote=c(0.1,0.9))
vote <- names(lpt)
exp <- list(libpts=lpt, voting=vote, cptparam=NULL,
            cpt=cbind(pos=10, val=x[10], nvote=2))
res2 <- merge.cpt(res, x, prm$qvote, prm$sep, prm$fsep, prm$libsep)
verify.cpt('BTP 2', res2, exp)

# Equivalent to running cpt on system without any detectors.
verify.warning('BTP 3', find.cpt,
               list(diff(sort(faithful$eruptions), lag=16),
                    c('-anomaly', '-astsa', '-bcp', '-breakfast', '-bwd',
                      '-ccid', '-changepoint', '-changepoint.np', '-cpm',
                      '-cpss', '-ecp', '-ICSS', '-jointseg', '-mosum', '-ocp',
                      '-otsad', '-Rbeast', '-strucchange', '-Dimodal'),
                    0.05, 2, c(0.10,0.90), 10,0.02, 2))


if (allpass) {
  cat('  all find.cpt tests PASSED\n')
}
