Package: SDEFSR
Type: Package
Title: Subgroup Discovery with Evolutionary Fuzzy Systems
Version: 0.7.22
Date: 2021-04-24
Authors@R: c(person("Angel M.", "Garcia", email = "agvico@ujaen.es",
        role = c("aut", "cre")), person("Pedro", "Gonzalez", email =
