Title: Processing of Accelerometry Data with 'GGIR' in mMARCH
Authors@R: c( person(given = "Wei", family = "Guo", role = c("aut",
        "cre"), email = "wei.guo3@nih.gov"), person(given = "Andrew",
        family = "Leroux", role = c("aut"), email =
