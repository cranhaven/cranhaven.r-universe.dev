Package: dgumbel
Type: Package
Title: The Gumbel Distribution Functions and Gradients
Version: 1.0.1
Date: 2020-04-07
Authors@R: c(person("Berent Ånund
        Strømnes","Lunde",role=c("aut","cre","cph"),email="lundeberent@gmail.com"),
