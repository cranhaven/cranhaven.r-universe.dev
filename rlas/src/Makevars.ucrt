PKG_CPPFLAGS =\
	-I$(RWINLIB)/include \
	-I./  -I./LASlib/ -I./LASzip/ \
	-DHAVE_PROJ_H \
	-DNDEBUG -DUNORDERED -DHAVE_UNORDERED_MAP -DUSING_R -DUSING_GDAL

ifeq (,$(shell pkg-config --version 2>/dev/null))
  LIBSHARPYUV = $(or $(and $(wildcard $(R_TOOLS_SOFT)/lib/libsharpyuv.a),-lsharpyuv),)
  PKG_LIBS =  \
-lgdal -larmadillo -lopenblas -lgfortran -lquadmath -lpq -lpgcommon -lpgport -lodbc32 -lodbccp32 -lblosc -lkea -lhdf5_cpp -lhdf5 -lpoppler -llcms2 -lfreetype -lharfbuzz -lfreetype -llz4 -lpcre2-8 -lxml2 -lopenjp2 -lnetcdf -lmysqlclient -lspatialite -lgeos_c -lgeos -lminizip -lgeos -ljson-c -lgta -lfreexl -lexpat -lssl -lpsapi -lgif -lmfhdf -lhdf5_hl -lcrypto -lportablexdr -ldf -lhdf5 -lsz -lpng16 -lpng -lpoppler -llcms2 -lfreetype -lharfbuzz -lfreetype -llz4 -lpcre2-8 -lpcre -lcurl -lbcrypt -lrtmp -lssl -lssh2 -lidn2 -lunistring -liconv -lgcrypt -lcrypto -lgpg-error -lws2_32 -ltiff -llzma -ljpeg -lz -lcfitsio -lzstd -lwebpdecoder -lwebp $(LIBSHARPYUV) -lsbml-static -lgeotiff -lproj -lsqlite3 -lbz2 -lcrypt32 -lwldap32 -lsecur32
else
  PKG_LIBS = $(shell pkg-config --libs gdal geos proj)
endif

SOURCES = LASlib/lasreader_txt.cpp \
					LASlib/fopen_compressed.cpp \
					LASlib/laswriter_las.cpp \
					LASlib/lasreaderbuffered.cpp \
					LASlib/lasreadermerged.cpp \
					LASlib/laswriter_wrl.cpp \
					LASlib/lasreader_shp.cpp \
					LASlib/lasreader_asc.cpp \
					LASlib/lasreaderstored.cpp \
					LASlib/lasreaderpipeon.cpp \
					LASlib/lasreader_bil.cpp \
					LASlib/lastransform.cpp \
					LASlib/laswaveform13writer.cpp \
					LASlib/laswaveform13reader.cpp \
					LASlib/laswritercompatible.cpp \
					LASlib/lasutility.cpp \
					LASlib/lasreader_dtm.cpp \
					LASlib/lasfilter.cpp \
					LASlib/lasignore.cpp \
					LASlib/laskdtree.cpp \
					LASlib/laswriter_qfit.cpp \
					LASlib/lasreader_qfit.cpp \
					LASlib/laswriter.cpp  \
					LASlib/lasreader.cpp \
					LASlib/lasreader_las.cpp \
					LASlib/lasreader_ply.cpp \
					LASlib/lasreader_bin.cpp \
					LASlib/laswriter_bin.cpp \
					LASlib/laswriter_txt.cpp \
					LASzip/laszip.cpp \
					LASzip/lasindex.cpp \
					LASzip/arithmeticmodel.cpp \
					LASzip/laswriteitemcompressed_v1.cpp \
					LASzip/laswriteitemcompressed_v2.cpp \
					LASzip/laswriteitemcompressed_v3.cpp \
					LASzip/laswriteitemcompressed_v4.cpp \
					LASzip/lasreaditemcompressed_v1.cpp \
					LASzip/lasreaditemcompressed_v2.cpp \
					LASzip/lasreaditemcompressed_v3.cpp \
					LASzip/lasreaditemcompressed_v4.cpp \
					LASzip/arithmeticdecoder.cpp \
					LASzip/arithmeticencoder.cpp \
					LASzip/lasquadtree.cpp \
					LASzip/laswritepoint.cpp \
					LASzip/lasreadpoint.cpp \
					LASzip/integercompressor.cpp \
					LASzip/lasinterval.cpp \
					LASzip/lascopc.cpp \
					./altrep_compact_replication.cpp \
					./rlasstreamer.cpp \
					./rlasextrabytesattributes.cpp \
					./readLAS.cpp \
					./readheader.cpp \
					./writeLAS.cpp \
					./writeLAX.cpp \
					./fast.cpp \
					./RcppExports.cpp

TEMP1   = $(SOURCES:.cpp=.o)
OBJECTS = $(TEMP1:.c=.o)

all: clean winlibs

winlibs:
	cp -r "$(R_TOOLS_SOFT)/share/gdal" ../inst/
	cp -r "$(R_TOOLS_SOFT)/share/proj" ../inst/

clean:
	rm -f $(SHLIB) $(OBJECTS)

.PHONY: all winlibs clean
