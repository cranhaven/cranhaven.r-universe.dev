#!/bin/bash
# configure.win - Simple pass-through for RcppCGAL

echo "Configuring ahull3D with RcppCGAL on Windows..."

# Write Makevars
echo "CXX_STD = CXX17" > src/Makevars
echo "PKG_CXXFLAGS = -DCGAL_HEADER_ONLY=1" >> src/Makevars
echo "PKG_LIBS = -lmpfr -lgmp" >> src/Makevars

echo "Configuration complete."
exit 0