Package: VARDetect
Type: Package
Title: Multiple Change Point Detection in Structural VAR Models
Version: 0.1.8
Author: Yue Bai [aut, cre], Peiliang Bai [aut], Abolfazl Safikhani
        [aut], George Michailidis [aut]
Authors@R: c(person("Yue", "Bai", email = "baiyue69@gmail.com", role =
        c("aut", "cre")), person("Peiliang", "Bai", email =
        "baiplstat@gmail.com", role = c("aut")), person("Abolfazl",
