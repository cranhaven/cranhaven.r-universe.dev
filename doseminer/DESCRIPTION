Package: doseminer
Type: Package
Title: Extract Drug Dosages from Free-Text Prescriptions
Version: 0.1.2
Authors@R: c(person(given = 'David', family = 'Selby', role = c('aut',
        'cre'), email = 'david.selby@manchester.ac.uk', comment =
        c(ORCID = '0000-0001-8026-5663')), person(given = 'Belay
