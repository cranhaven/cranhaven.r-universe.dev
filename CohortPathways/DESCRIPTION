Package: CohortPathways
Type: Package
Title: Create Pathways from Target to Event Cohorts
Version: 0.0.1
Date: 2025-03-18
Authors@R: c( person("Gowtham", "Rao", email = "rao@ohdsi.org", role =
        c("aut", "cre")), person("Chris", "Knoll", email =
