Type: Package
Package: ARUtools
Title: Management and Processing of Autonomous Recording Unit (ARU)
        Data
Version: 0.7.2
Authors@R: c( person("David", "Hope", , "david.hope@ec.gc.ca", role =
        c("aut", "cre"), comment = c(ORCID = "0000-0002-2140-4261")),
        person("Steffi", "LaZerte", , "sel@steffilazerte.ca", role =
