Package: mathml
Type: Package
Title: Translate R Expressions to 'MathML' and 'LaTeX'/'MathJax'
Version: 1.8
Date: 2026-05-22
Authors@R: c(person("Matthias", "Gondan", role=c("aut", "cre", "cph"),
        email="Matthias.Gondan-Rochon@uibk.ac.at", comment="University
