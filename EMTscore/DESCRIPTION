Package: EMTscore
Type: Package
Title: Calculate 'EMT' Scores Based on 'Omics' Data
Version: 0.1.1
Date: 2025-04-11
Authors@R: c(person(given = "Haimei", family = "Wen", email =
        "hudie.luoluo@gmail.com", role = c("aut", "cre")),person(given
