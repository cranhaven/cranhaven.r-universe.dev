Package: RJcluster
Title: A Fast Clustering Algorithm for High Dimensional Data Based on
        the Gram Matrix Decomposition
Version: 3.2.4
Authors@R: c(person(given = "Shahina", family = "Rahman", role =
        c("aut"), email = "srahman@stat.tamu.edu"), person(given =
        "Valen E.", family = "Johnson", role = c("aut"), email =
        "vejohnson@exchange.tamu.edu"), person(given = "Suhasini",
        family = "Subba Rao", role = c("aut"), email =
        "suhasini@stat.tamu.edu"), person(given = "Rachael", family =
