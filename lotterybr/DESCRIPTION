Package: lotterybr
Title: Lottery Datasets from Caixa Economica Federal
Version: 0.2.0
Authors@R: c( person("Tomas", "Bernardes", email = "tomasbp@ufmg.br",
        role = c("aut", "cre", "cph")), person("Salvador", "Netto",
        email = "salvnetto@ufmg.br", role = "aut"), person(given =
