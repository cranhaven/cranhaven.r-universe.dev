Package: PerMallows
Type: Package
Title: Permutations and Mallows Distributions
Version: 1.15
Date: 2025-05-04
Authors@R: c( person(given = "Ekhine", family = "Irurozki", role =
        c("aut", "cre"), email = "irurozki@telecom-paris.fr"),
        person(given = "Borja", family = "Calvo", role = "aut", email =
