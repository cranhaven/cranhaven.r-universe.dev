Package: mra
Type: Package
Title: Mark-Recapture Analysis
Version: 2.16.11
Date: 2018-01-04
Authors@R: c( person("Trent", "McDonald",
        email="tmcdonald@west-inc.com", role=c("cre","aut")),
        person("Eric", "Regehr", email="eric_regehr@fws.gov",
