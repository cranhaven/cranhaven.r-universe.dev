Type: Package
Package: glossa
Title: User-Friendly 'shiny' App for Bayesian Species Distribution
        Models
Version: 1.2.1
Authors@R: c( person("Jorge", "Mestre-Tomás", ,
        "jorge.mestre.tomas@csic.es", role = c("aut", "cre"), comment =
